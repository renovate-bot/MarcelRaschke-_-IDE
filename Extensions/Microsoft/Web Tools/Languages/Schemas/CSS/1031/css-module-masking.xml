<CssModule name="Masking" standard-reference="https://www.w3.org/TR/css-masking-1/" status="CR" pub-date="2021-08-05">

  <!-- This extends shape-box, which itself extends box. See https://www.w3.org/TR/css-masking-1/#typedef-geometry-box -->
  <CssPropertyValue type="geometry-box">
    <entry _locID="geometry-box_border-box" _locAttrData="description" value="border-box" description="Definiert die Form, die von der äußeren Kante des Rahmens umschlossen wird." />
    <entry _locID="geometry-box_padding-box" _locAttrData="description" value="padding-box" description="Definiert die Form, die von der äußeren Kante des Innenabstands umschlossen wird." />
    <entry _locID="geometry-box_content-box" _locAttrData="description" value="content-box" description="Definiert die Form, die von der äußeren Kante des Inhalts umschlossen wird." />
    <entry _locID="geometry-box_margin-box" _locAttrData="description" value="margin-box" description="Definiert die Form, die von der äußeren Kante des Rands umschlossen wird." />
    <entry _locID="geometry-box_fill-box" _locAttrData="description" value="fill-box" description="Verwendet den Begrenzungsrahmen des Objekts als Referenzrahmen." />
    <entry _locID="geometry-box_stroke-box" _locAttrData="description" value="stroke-box" description="Verwendet den Begrenzungsrahmen des Strichs als Referenzrahmen." />
    <entry _locID="geometry-box_view-box" _locAttrData="description" value="view-box" description="Verwendet den nächsten SVG-Anzeigebereich als Referenzrahmen." />
  </CssPropertyValue>


  <CssProperty _locID="clip-path" _locAttrData="description" type="geometry-box, basic-shape, url" description="Definiert die Formel, die zum Mischen der Farben mit dem Hintergrund verwendet werden muss." syntax="sub { $(name): ellipse(130px 140px at 10% 20%); }" standard-reference="https://www.w3.org/TR/css-masking-1/#the-clip-path">
    <entry value="none" />
  </CssProperty>

  <CssProperty _locID="clip-rule" _locAttrData="description" version="3.0" restriction="enum" description="Gibt den Algorithmus an, mit dessen Hilfe für einen mit einem Grafikelement erstellten Clippingbereich ermittelt werden soll, ob ein bestimmter Punkt sich innerhalb einer Form befindet." standard-reference="https://www.w3.org/TR/css-masking-1/#the-clip-rule">

    <entry _locID="clip-rule_nonzero" _locAttrData="description" value="nonzero" description="Diese Regel bestimmt, ob sich ein Punkt innerhalb der Zeichenfläche befindet, indem ein unendlicher Strahl von diesem Punkt in eine beliebige Richtung gezeichnet und anschließend die Schnittpunkte des Strahls mit einem Segment der Form überprüft werden." />
    <entry _locID="clip-rule_evenodd" _locAttrData="description" value="evenodd" description="Diese Regel bestimmt, ob sich ein Punkt innerhalb der Zeichenfläche befindet, indem ein unendlicher Strahl von diesem Punkt in eine beliebige Richtung gezeichnet und die Anzahl der vom Strahl geschnittenen Pfadsegmente in der angegebenen Form gezählt wird." />
  </CssProperty>

  <CssProperty _locID="mask-image" _locAttrData="description" version="4.0" restriction="enum, url" type="image" description="Legt das Maskenebenenbild eines Elements fest." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-image">
    <entry value="none" />
  </CssProperty>

  <CssPropertyValue type="masking-mode">
    <entry value="alpha" />
    <entry value="luminance" />
    <entry value="auto" />
  </CssPropertyValue>

  <CssProperty _locID="mask-mode" _locAttrData="description" version="4.0" restriction="enum" type="masking-mode" description="Gibt an, ob die Maske als Leuchtdichte- oder als Alphamaske behandelt wird." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-mode" />

  <CssProperty _locID="mask-repeat" _locAttrData="description" version="4.0" restriction="enum" type="background-repeat" description="Gibt an, wie Maskenebenenbilder nach dem Dimensionieren und Positionieren neben- bzw. untereinander angeordnet werden." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-repeat" />

  <CssProperty _locID="mask-position" _locAttrData="description" version="4.0" restriction="enum, length, percentage" type="background-position" description="Gibt die Anfangsposition der Maske (nach einer Größenänderung) innerhalb des zugehörigen Hintergrundpositionierungsbereichs an." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-position" />

  <CssProperty _locID="mask-clip" _locAttrData="description" version="4.0" restriction="enum" type="geometry-box" description="Gibt die Anfangsposition der Maske (nach einer Größenänderung) innerhalb des zugehörigen Hintergrundpositionierungsbereichs an." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-clip">
    <entry value="no-clip" />
  </CssProperty>

  <CssProperty _locID="mask-origin" _locAttrData="description" version="4.0" restriction="enum" type="geometry-box" description="Gibt bei Elementen, die als Einzelbox dargestellt werden, den Maskenpositionierungsbereich an. Bei Elementen, die in Form mehrerer Boxen dargestellt werden (z.B. Inlineboxen über mehrere Zeilen oder Boxen über mehrere Seiten) gibt diese Eigenschaft an, für welche Boxen &quot;box-decoration-break&quot; den Maskenpositionierungsbereich festlegt." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-origin" />

  <CssProperty _locID="mask-size" _locAttrData="description" version="4.0" restriction="length, percentage" type="bg-size" description="Gibt die Größe der Maskenebenenbilder an." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-size" />

  <CssPropertyValue type="compositing-operator">
    <entry value="add" />
    <entry value="subtract" />
    <entry value="intersect" />
    <entry value="exclude" />
  </CssPropertyValue>

  <CssProperty _locID="mask-composite" _locAttrData="description" version="4.0" restriction="enum" type="compositing-operator" description="Definiert den Zusammensetzungsvorgang der aktuellen Maskenebene mit den darunter liegenden Maskenebenen." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-composite" />

  <CssProperty _locID="mask" _locAttrData="description" version="4.0" type="image, masking-mode, background-position, bg-size, background-repeat, geometry-box, compositing-operator" description="Kompakteigenschaft zum Festlegen von Maskenbild, Modus, Wiederholung, Position, Clipping, Ursprung, Größe und Zusammensetzung" standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask">
    <entry value="none" />
    <entry value="no-clip" />
  </CssProperty>

  <CssProperty _locID="mask-border-source" _locAttrData="description" version="4.0" restriction="enum, url" type="image" description="Gibt ein Bild an, das als Maskenrahmenbild verwendet werden soll." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-source">
    <entry value="none" />
  </CssProperty>

  <CssProperty _locID="mask-border-mode" _locAttrData="description" version="4.0" restriction="enum" description="Die Eigenschaft &quot;mask-border-mode&quot; gibt an, ob der Bildwert für &quot;mask-border-source&quot; als Leuchtdichtemaske oder als Alphamaske behandelt wird." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-mode">
    <entry value="alpha" />
    <entry value="luminance" />
  </CssProperty>

  <CssProperty _locID="mask-border-slice" _locAttrData="description" version="4.0" restriction="length, percentage" description="Diese Eigenschaft gibt die inneren Offsets von der oberen, rechten, unteren und linken Kante des Maskenrahmenbilds an. Das Bild wird in neun Bereiche unterteilt: vier Ecken, vier Kanten und eine Mitte. Der mittlere Bildteil wird verworfen und als vollständig deckendes Weiß behandelt (der vom mittleren Teil abgedeckte Inhalt wird nicht maskiert und scheint durch), sofern das fill-Schlüsselwort nicht vorhanden ist." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-slice">
    <entry value="fill" />
  </CssProperty>

  <CssProperty _locID="mask-border-width" _locAttrData="description" version="4.0" restriction="number, length, percentage" description="Das Maskenrahmenbild wird innerhalb eines Bereichs gezeichnet, der als Maskenrahmenbild-Bereich bezeichnet wird." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-width">
    <entry value="auto" />
  </CssProperty>

  <CssProperty _locID="mask-border-outset" _locAttrData="description" version="4.0" restriction="length, percentage" description="Die Werte geben den Umfang an, um den der Maskenrahmenbild-Bereich über die Rahmenbox hinausreicht. Wenn vier Werte vorliegen, legen diese den jeweiligen Anfang auf der oberen, der rechten, der unteren und der linken Seite (in dieser Reihenfolge) fest. Wenn der Wert für den linken Rand fehlt, entspricht er dem des rechten Rands. Wenn der Wert für den unteren Rand fehlt, ist er mit dem Wert des oberen Rands identisch. Wenn der Wert für den rechten Rand fehlt, stimmt er mit dem des oberen Rands überein." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-outset">
  </CssProperty>

  <CssProperty _locID="mask-border-repeat" _locAttrData="description" version="4.0" restriction="enum" type="border-image-repeat" description="Diese Eigenschaft gibt an, wie die Bilder für die Seiten und den mittleren Teil des Maskenrahmenbilds skaliert und neben- bzw. untereinander angeordnet werden. Das erste Schlüsselwort gilt für die horizontalen Seiten, das zweite für die vertikalen. Wenn das zweite Schlüsselwort fehlt, wird derselbe Wert wie für das erste verwendet." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border-repeat" />

  <CssProperty _locID="mask-border" _locAttrData="description" version="4.0" restriction="enum, length, percentage, url" type="border-image-repeat, image" description="Dies ist eine Kompakteigenschaft zum Festlegen von &quot;mask-border-source&quot;, &quot;mask-border-slice&quot;, &quot;mask-border-width&quot;, &quot;mask-border-outset&quot; und &quot;mask-border-repeat&quot;." standard-reference="https://www.w3.org/TR/css-masking-1/#the-mask-border">
    <entry value="none" />
    <entry value="auto" />
    <entry value="fill" />
    <entry value="alpha" />
    <entry value="luminance" />
  </CssProperty>

