<CssModule name="Filter Effects" standard-reference="https://drafts.fxtf.org/filter-effects-2/" status="ED" pub-date="2020-07-16">

  <CssPropertyValue type="filter-functions">
    <entry _locID="filter-function_blur" _locAttrData="description" value="blur()" description="Wendet eine Gaußschen Weichzeichner auf das Eingabebild an." />
    <entry _locID="filter-function_brightness" _locAttrData="description" value="brightness()" description="Wendet einen linearen Multiplikator auf das Eingabebild an, sodass es heller oder dunkler erscheint." />
    <entry _locID="filter-function_contrast" _locAttrData="description" value="contrast()" description="Passt den Kontrast der Eingabe an." />
    <entry _locID="filter-function_drop-shadow" _locAttrData="description" value="drop-shadow()" description="Wendet einen Schlagschatteneffekt auf das Eingabebild an." />
    <entry _locID="filter-function_grayscale" _locAttrData="description" value="grayscale()" description="Konvertiert das Eingabebild in Graustufen." />
    <entry _locID="filter-function_hue-rotate" _locAttrData="description" value="hue-rotate()" description="Wendet eine Farbtonrotation auf das Eingabebild an." />
    <entry _locID="filter-function_invert" _locAttrData="description" value="invert()" description="Invertiert die Farbmuster im Eingabebild." />
    <entry _locID="filter-function_opacity" _locAttrData="description" value="opacity()" description="Wendet Transparenz auf die Farbmuster im Eingabebild an." />
    <entry _locID="filter-function_saturate" _locAttrData="description" value="saturate()" description="Sättigt die Farben im Eingabebild." />
    <entry _locID="filter-function_sepia" _locAttrData="description" value="sepia()" description="Konvertiert das Eingabebild in Sepia." />
  </CssPropertyValue>

  <CssProperty _locID="filter" _locAttrData="description" restriction="enum, url" type="url, filter-functions" syntax="div { $(name): blur(5px); }" description="Die erste Filterfunktion oder der erste Filterverweis in der Liste verwendet das Element als Eingabebild. Durch nachfolgende Vorgänge wird die Ausgabe der vorherigen Filterfunktion oder des vorherigen Filterverweises als Eingabebild übernommen." standard-reference="https://drafts.csswg.org/cssom-view/#smooth-scrolling">

      <entry _locID="filter-none" _locAttrData="description" value="none" description="Es wird kein Filtereffekt angewendet." />
  </CssProperty>

  <CssProperty _locID="backdrop-filter" ref="filter" />

  <CssProperty _locID="color-interpolation-filters" _locAttrData="description" restriction="enum" description="Gibt den Farbraum für Bilderzeugungsvorgänge an, die über Filtereffekte ausgeführt werden." standard-reference="https://www.w3.org/TR/filter-effects-1/#ColorInterpolationFiltersProperty">

    <entry value="auto" />
    <entry value="sRGB" />
    <entry value="linearRGB" />
  </CssProperty>

  <CssProperty _locID="lighting-color" _locAttrData="description" restriction="color" description="Die Lichtfarben-Eigenschaft definiert die Farbe der Lichtquelle für die Filterprimitiven „feDiffuseLighting“ und „feSpecularLighting“." standard-reference="https://www.w3.org/TR/filter-effects-1/#LightingColorProperty" />

