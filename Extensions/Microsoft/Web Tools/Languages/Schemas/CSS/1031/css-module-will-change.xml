<CssModule name="Will Change" standard-reference="https://www.w3.org/TR/css-will-change-1/" status="WD" pub-date="2015-12-03">

    <CssProperty _locID="will-change" _locAttrData="description" version="3.0" browsers="C,FF,O" restriction="enum, identifier" syntax="div { $(name): transform; }" description="Stellt einen Renderinghinweis für den Benutzer-Agent zur Verfügung, der angibt, welche Arten von Änderungen der Autor für das Element erwartet." standard-reference="https://www.w3.org/TR/css-will-change-1/#will-change">

        <entry _locID="will-change-auto" _locAttrData="description" value="auto" description="Gibt keine bestimmte Absicht an. Der Benutzer-Agent soll die Heuristiken und Optimierungen anwenden, die er üblicherweise anwendet." />
        <entry _locID="will-change-scroll-position" _locAttrData="description" value="scroll-position" description="Gibt an, dass der Autor erwartet, die Bildlaufposition des Elements in naher Zukunft zu animieren oder zu ändern." />
        <entry _locID="will-change-contents" _locAttrData="description" value="contents" description="Gibt an, dass der Autor erwartet, Inhalte des Elements in naher Zukunft zu animieren oder zu ändern." />
    </CssProperty>
