<CssModule name="CSS Level 2 Revision 1" standard-reference="https://www.w3.org/TR/CSS2/" status="REC" pub-date="2011-06-07">

  <!-- Section 4: Syntax and basic data types -->
  <CssAtDirective name="charset" _locID="charset-rule" _locAttrData="description, syntax" version="1.0" browsers="all" restriction="string" syntax="@charset 'utf-8';" description="Definiert den Zeichensatz des Dokuments." standard-reference="https://www.w3.org/TR/CSS2/syndata.html#x57" />

  <!-- Section 6: Assigning property values, Cascading, and Inheritance -->
  <CssAtDirective name="import" _locID="import-rule" _locAttrData="description" version="1.0" browsers="all" syntax="@import url('file.css') tv, print;" description="Importiert Inhalte aus einer anderen Datei." standard-reference="https://www.w3.org/TR/CSS2/cascade.html#at-import" />

  <!-- Section 9: Visual Formatting Model -->
  <CssProperty _locID="position" version="2.0" restriction="enum" syntax="div { $(name): absolute; }" standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-position">

      <entry _locID="position_absolute" _locAttrData="description" value="absolute" description="Die Position (und möglicherweise Größe) der Box wird über die Eigenschaften 'top', 'right', 'bottom' und 'left' angegeben. Diese Eigenschaften legen die Abstände in Bezug zum 'umschließenden Block' der Box fest." />
      <entry _locID="position_fixed" _locAttrData="description" value="fixed" description="Die Position der Box wird gemäß dem absoluten Modell berechnet, zusätzlich wird die Position jedoch unter Beachtung einiger Angaben fixiert. Wie beim absoluten Modell fallen die Ränder der Box nicht mit anderen Rändern zusammen." />
      <entry _locID="position_relative" _locAttrData="description" value="relative" description="Die Position der Box wird gemäß dem normalen Fluss berechnet (und folglich als Positionierung im normalen Fluss bezeichnet). Anschließend wird die Box relativ zu ihrer normalen Position versetzt." />
      <entry _locID="position_static" _locAttrData="description" value="static" description="Eine normale Box, die entsprechend dem normalen Fluss positioniert wird. Die Eigenschaften 'top', 'right', 'bottom' und 'left' werden nicht angewendet." />
      <entry _locID="position_sticky" _locAttrData="description" value="sticky" description="Die Position der Box wird gemäß dem normalen Fluss berechnet. Die Box wird dann relativ zu ihrem Flussstamm und dem umschließenden Block versetzt. In allen Fällen (einschließlich Tabellenelementen) wirkt sich dies nicht auf die Position folgender Boxen aus." />
      <entry _locID="position_center" _locAttrData="description" value="center" description="Zentrierte Boxen werden aus dem normalen Fluss ausgeschlossen. Dies bedeutet, dass sie keinerlei Auswirkungen auf das Layout späterer gleichgeordneter Elemente besitzen." />
      <entry _locID="position_page" _locAttrData="description" value="page" description="Die Position der Box wird gemäß dem absoluten Modell berechnet." />
  </CssProperty>

  <CssProperty _locID="left" _locAttrData="description" version="2.0" restriction="length, percentage" description="Gibt an, wie groß der Abstand des linken Rands einer absolut positionierten Box zum inneren linken Rand des 'umschließenden Blocks' der Box ist." syntax="article { $(name): 50px; }" standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-left">

      <entry _locID="left_auto" _locAttrData="description" value="auto" description="Wie sich dieser Wert bei nicht ersetzten Elementen auswirkt, hängt von den verknüpften Eigenschaften ab, die ebenfalls den Wert 'Auto' aufweisen." />
  </CssProperty>

  <CssProperty _locID="top" _locAttrData="description" ref="left" description="Gibt an, wie groß der Abstand des oberen Rands einer absolut positionierten Box zum oberen Rand des 'umschließenden Blocks' der Box ist." standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-top" />

  <CssProperty _locID="right" _locAttrData="description" ref="left" description="Gibt an, wie groß der Abstand des rechten Rands einer absolut positionierten Box zum inneren rechten Rand des 'umschließenden Blocks' der Box ist." standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-right" />

  <CssProperty _locID="bottom" _locAttrData="description" ref="left" description="Gibt an, wie groß der Abstand des unteren Rands einer absolut positionierten Box zum inneren unteren Rand des 'umschließenden Blocks' der Box ist." standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-bottom" />


  <CssProperty _locID="float" _locAttrData="description" version="1.0" restriction="enum" syntax="img { $(name): right; }" description="Gibt an, wie eine Box umflossen wird. Diese Eigenschaft kann für beliebige Elemente festgelegt werden, gilt jedoch nur für Elemente, die Boxen ohne absolute Positionierung erzeugen." standard-reference="https://www.w3.org/TR/CSS2/visuren.html#float-position">

    <entry _locID="float_left" _locAttrData="description" value="left" description="Das Element erzeugt eine Blockbox, die links ausgerichtet wird. Der weitere Inhalt umfließt von oben ausgehend (je nach Festlegung der 'clear'-Eigenschaft) die rechte Seite der Box." />
    <entry _locID="float_right" _locAttrData="description" value="right" description="Ähnlich wie 'left', außer dass die Box rechts ausgerichtet wird und der weitere Inhalt von oben ausgehend die linke Seite der Box umfließt." />
    <entry _locID="float_none" _locAttrData="description" value="none" description="Es findet kein Umfluss statt." />
  </CssProperty>

  <CssProperty _locID="clear" _locAttrData="description" version="1.0" restriction="enum" description="Gibt an, auf welchen Seiten der Elementbox keine vorhergehenden float-positionierten Elemente dargestellt werden dürfen. Durch die 'clear'-Eigenschaft werden 'floats' innerhalb des Elements oder in anderen Blockformatierungen nicht berücksichtigt." syntax="footer { $(name): both; }" standard-reference="https://www.w3.org/TR/CSS2/visuren.html#flow-control">

    <entry _locID="clear_none" _locAttrData="description" value="none" description="float-Elemente können auf beiden Seiten der Box erscheinen." />
    <entry _locID="clear_left" _locAttrData="description" value="left" description="Der Abstand der erzeugten Box wird so weit ausgedehnt, bis die obere Außenkante des Rahmens unter der unteren Außenkante aller vorangehenden links-floatierten Elemente liegt, die aus vorhergehenden Elementen im Quelldokument resultieren." />
    <entry _locID="clear_right" _locAttrData="description" value="right" description="Der Abstand der erzeugten Box wird so weit ausgedehnt, bis die obere Außenkante des Rahmens unter der unteren Außenkante aller vorangehenden rechts-floatierten Elemente liegt, die aus vorhergehenden Elementen im Quelldokument resultieren." />
    <entry _locID="clear_both" _locAttrData="description" value="both" description="Der Abstand der erzeugten Box wird so weit ausgedehnt, bis die obere Außenkante des Rahmens unter der unteren Außenkante aller vorangehenden rechts- und links-floatierten Elemente liegt, die aus vorhergehenden Elementen im Quelldokument resultieren." />
  </CssProperty>

  <CssProperty _locID="z-index" _locAttrData="description" version="2.0" restriction="integer" description="Bei einer positionierten Box gibt die 'z-index'-Eigenschaft die Stapelebene der Box im aktuellen Stapelkontext an und ob ein lokaler Stapelkontext von der Box festgelegt wird." syntax="img { $(name): 3; }" standard-reference="https://www.w3.org/TR/CSS2/visuren.html#propdef-z-index">

    <entry _locID="z-index_auto" _locAttrData="description" value="auto" description="Die Stapelebene der generierten Box im aktuellen Stapelkontext lautet '0'. Von der Box wird erst ein neuer Stapelkontext eingerichtet, wenn es sich um das Stammelement handelt." />
  </CssProperty>

  <!-- Section 10: Visual formatting model details -->
  <CssProperty _locID="line-height" _locAttrData="description" version="1.0" restriction="number, length, percentage" description="Legt die 'block-progression-dimension' des Textinhaltsbereichs einer Inlinebox fest." syntax="#menu { $(name): 22px; }" standard-reference="https://www.w3.org/TR/CSS2/visudet.html#propdef-line-height">
      <entry _locID="line-height_normal" _locAttrData="description" value="normal" description="Weist die Benutzer-Agents an, den berechneten Wert in Bezug zum Schriftgrad des Elements auf einen angemessenen Wert festzulegen." />
  </CssProperty>

  <CssProperty _locID="vertical-align" _locAttrData="description" version="1.0" restriction="percentage, length" description="Wirkt sich auf die vertikale Positionierung der Inlineboxen aus, die von einem Inline-Level-Element innerhalb einer Zeilenbox erzeugt wurden." syntax="div { $(name): middle; }" standard-reference="https://www.w3.org/TR/CSS2/visudet.html#propdef-vertical-align">

      <entry _locID="vertical-align_baseline" _locAttrData="description" value="baseline" description="Richtet die als 'alphabetic' festgelegte Grundlinie des Elements auf die als 'alphabetic' festgelegte Grundlinie des übergeordneten Elements aus." />
      <entry _locID="vertical-align_sub" _locAttrData="description" value="sub" description="Senkt die Grundlinie der Box auf die richtige Position für tiefgestellte Elemente in der Box des übergeordneten Elements ab. (Dieser Wert wirkt sich nicht auf die Schriftartgröße des Elementtexts aus.)" />
      <entry _locID="vertical-align_super" _locAttrData="description" value="super" description="Hebt die Grundlinie der Box auf die richtige Position für hochgestellte Elemente in der Box des übergeordneten Elements an. (Dieser Wert wirkt sich nicht auf die Schriftartgröße des Elementtexts aus.)" />
      <entry _locID="vertical-align_top" _locAttrData="description" value="top" description="Richtet 'before-edge' der erweiterten Inlinebox auf 'before-edge' der Zeilenbox aus." />
      <entry _locID="vertical-align_text-top" _locAttrData="description" value="text-top" description="Richtet den oberen Rand der Box auf 'before-edge' der Schriftart des übergeordneten Elements aus." />
      <entry _locID="vertical-align_bottom" _locAttrData="description" value="bottom" description="Richtet 'after edge' der erweiterten Inlinebox auf 'after-edge' der Zeilenbox aus." />
      <entry _locID="vertical-align_text-bottom" _locAttrData="description" value="text-bottom" description="Richtet den unteren Rand der Box auf 'after-edge' der Schriftart des übergeordneten Elements aus." />
      <entry _locID="vertical-align_auto" _locAttrData="description" value="auto" version="3.0" description="Richtet die 'dominant-baseline' der Box des übergeordneten Elements auf die äquivalente oder heuristisch neu erstellte Grundlinie der Inlinebox des Elements aus." />
      <entry _locID="vertical-align_use-script" _locAttrData="description" value="use-script" version="3.0" browsers="none" description="Richtet die vom Schriftsystem bevorzugte Grundlinie des Elements (die durch den berechneten Wert des Schriftsystems festgelegt wird) auf die äquivalente Grundlinie des übergeordneten Elements aus." />
      <entry _locID="vertical-align_central" _locAttrData="description" value="central" browsers="none" version="3.0" description="Richtet die 'central'-Grundlinie des Inlineelements auf die 'central'-Grundlinie des übergeordneten Elements aus." />
      <entry _locID="vertical-align_middle" _locAttrData="description" value="middle" version="3.0" description="Richtet die 'middle'-Grundlinie des Inlineelements auf die 'middle'-Grundlinie des übergeordneten Elements aus." />
  </CssProperty>


  <!-- Section 11: Visual Effects -->
  <CssProperty _locID="visibility" _locAttrData="description" version="2.0" browsers="all" restriction="enum" syntax="img { $(name): hidden; }" description="Gibt an, ob die von einem Element erzeugten Boxen sichtbar dargestellt werden. Unsichtbare Boxen wirken sich weiterhin auf das Layout aus (legen Sie die 'display'-Eigenschaft auf 'none' fest, um die Erstellung von Boxen insgesamt zu unterbinden)." standard-reference="https://www.w3.org/TR/CSS2/visufx.html#visibility">

    <entry _locID="visibility_visible" _locAttrData="description" value="visible" description="Die erzeugte Box ist sichtbar." />
    <entry _locID="visibility_hidden" _locAttrData="description" value="hidden" description="Die erzeugte Box ist unsichtbar (vollständig transparent, nichts wird gezeichnet); sie wirkt sich jedoch weiterhin auf das Layout aus." />
    <entry _locID="visibility_collapse" _locAttrData="description" value="collapse" description="Tabellenspezifisch. Wenn diese Eigenschaft für andere Elemente als Zeilen, Zeilengruppen, Spalten oder Spaltengruppen verwendet wird, hat 'collapse' die gleiche Auswirkung wie 'hidden'." />
  </CssProperty>

  <CssProperty _locID="clip" _locAttrData="description, syntax" version="2.0" browsers="all" restriction="enum" description="Definiert den sichtbaren Teil einer Elementbox." syntax="span { $(name): rect(0px, 60px, 200px, 0px); }&#xD;&#xA;        span { $(name): rect(top, right, bottom, left); }" standard-reference="https://www.w3.org/TR/CSS2/visufx.html#clipping">

    <entry value="auto" />
    <entry value="rect()" />
  </CssProperty>

  <!-- Section 17: Tables -->
  <CssProperty _locID="caption-side" _locAttrData="description" version="2.0" browsers="C,FF,IE8,O,S" restriction="enum" syntax="caption { $(name): bottom; }" description="Gibt die Position der Überschrift in Relation zur Tabelle an." standard-reference="https://www.w3.org/TR/CSS2/tables.html#propdef-caption-side">

    <entry _locID="caption-side_top" _locAttrData="description" value="top" description="Positioniert die Überschrift oberhalb der Tabelle." />
    <entry _locID="caption-side_bottom" _locAttrData="description" value="bottom" description="Positioniert die Überschrift unterhalb der Tabelle." />
  </CssProperty>

  <CssProperty _locID="table-layout" _locAttrData="description" version="2.0" browsers="all" restriction="enum" syntax="table { $(name): fixed; }" description="Steuert den Algorithmus zum Erstellen von Zellen, Zeilen und Spalten in der Tabelle." standard-reference="https://www.w3.org/TR/CSS2/tables.html#propdef-table-layout">

    <entry _locID="table-layout_auto" _locAttrData="description" value="auto" description="Verwendet einen automatischen Algorithmus für das Tabellenlayout." />
    <entry _locID="table-layout_fixed" _locAttrData="description" value="fixed" description="Verwendet einen festen Algorithmus für das Tabellenlayout." />
  </CssProperty>

  <CssProperty _locID="border-collapse" _locAttrData="description" version="2.0" restriction="enum" syntax="table { $(name): collapse; }" description="Wählt das Rahmenmodell für eine Tabelle aus." standard-reference="https://www.w3.org/TR/CSS2/tables.html#borders">

    <entry _locID="border-collapse_collapse" _locAttrData="description" value="collapse" description="Wählt das Modell mit zusammenfallenden Rahmen aus." />
    <entry _locID="border-collapse_separate" _locAttrData="description" value="separate" description="Wählt das Modell mit getrennten Rahmen aus." />
  </CssProperty>

  <CssProperty _locID="border-spacing" _locAttrData="description" version="2.0" browsers="C,FF1,IE8,O7,S1.2" restriction="length" description="Die Längen geben den Abstand zwischen angrenzenden Tabellenzellen an. Wenn eine Länge angegeben wird, steht sie sowohl für den horizontalen als auch für den vertikalen Abstand. Wenn zwei Längen angegeben werden, gibt die erste den horizontalen Abstand und die zweite den vertikalen Abstand an. Längenwerte dürfen nicht negativ sein." syntax="table { $(name): 10px 50px; }" standard-reference="https://www.w3.org/TR/CSS2/tables.html#borders" />

  <CssProperty _locID="empty-cells" _locAttrData="description" version="2.0" browsers="C,FF1,IE7,O4,S1.2" restriction="enum" syntax="table { $(name): hide; }" description="Im Modell mit getrennten Rahmen steuert diese Eigenschaft die Darstellung von Rahmen und Hintergründen in Zellen, die über keinen sichtbaren Inhalt verfügen." standard-reference="https://www.w3.org/TR/CSS2/tables.html#empty-cells">

    <entry _locID="empty-cells_show" _locAttrData="description" value="show" description="Rahmen und Hintergründe werden um bzw. hinter leeren Zellen gezeichnet (wie bei normalen Zellen)." />
    <entry _locID="empty-cells_hide" _locAttrData="description" value="hide" description="Es werden keine Rahmen oder Hintergründe um bzw. hinter leeren Zellen gezeichnet." />
  </CssProperty>

  <!-- Appendix A: Aural style sheets -->
  <CssProperty _locID="volume" _locAttrData="description" version="2.0" browsers="none" restriction="percentage, number" description="Die Lautstärke entspricht der mittleren Stärke der Waveform, d.h., eine hohe Tonlage mit der Lautstärke 50 kann leicht darüber liegen." syntax="&lt;number&gt; | &lt;percentage&gt; | silent | x-soft | soft | medium | loud | x-loud" standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-volume">

    <entry _locID="volume_silent" _locAttrData="description" value="silent" description="Überhaupt keine Tonausgabe. Der Wert '0' ist nicht gleichbedeutend mit 'silent'." />
    <entry _locID="volume_x-soft" _locAttrData="description" value="x-soft" description="Identisch mit '0'." />
    <entry _locID="volume_soft" _locAttrData="description" value="soft" description="Identisch mit '25'." />
    <entry _locID="volume_medium" _locAttrData="description" value="medium" description="Identisch mit '50'." />
    <entry _locID="volume_loud" _locAttrData="description" value="loud" description="Identisch mit '75'." />
    <entry _locID="volume_x-loud" _locAttrData="description" value="x-loud" description="Identisch mit '100'." />
  </CssProperty>

  <CssProperty _locID="speak" _locAttrData="description" version="2.0" browsers="none" restriction="enum" syntax="div { $(name): normal; }" description="Gibt an, ob Text akustisch ausgegeben wird, und falls ja, auf welche Weise dies geschieht." standard-reference="https://www.w3.org/TR/2011/REC-CSS2-20110607/aural.html#speaking-props">

    <entry _locID="speak_none" _locAttrData="description" value="none" description="Unterdrückt die akustische Ausgabe, sodass das Element keine Renderingzeit erfordert." />
    <entry _locID="speak_normal" _locAttrData="description" value="normal" description="Verwendet sprachabhängige Ausspracheregeln für die Ausgabe eines Elements und seiner untergeordneten Elemente. Satzzeichen werden nicht mitgesprochen, aber auf natürliche Weise wiedergegeben, z.B. in Form von Sprechpausen." />
    <entry _locID="speak_spell-out" _locAttrData="description" value="spell-out" description="Buchstabiert den Text Zeichen für Zeichen (hilfreich bei Akronymen und Abkürzungen). Bei Sprachen mit wenigen Akzentzeichen können Akzente zugunsten alternativer Schreibweisen ohne Akzent ausgelassen werden." />
  </CssProperty>

  <CssProperty _locID="play-during" _locAttrData="description" version="2.0-2.1" browsers="none" restriction="url" type="url" description="Ein Hintergrundsound, der bei der Darstellung des Elementinhalts abgespielt werden soll." syntax="&lt;uri&gt; [ mix || repeat ]? | auto | none" standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-play-during">

    <entry _locID="play-during_mix" _locAttrData="description" value="mix" description="Der von der 'play-during'-Eigenschaft des übergeordneten Elements geerbte Sound wird weiter abgespielt und mit dem von &lt;uri&gt; angegebenen Sound vermischt." />
    <entry _locID="play-during_repeat" _locAttrData="description" value="repeat" description="Wenn der Sound zu kurz ist, wird er so lange wiederholt, wie die Ausgabe des ganzen Elements dauert. Andernfalls wird der Sound einmal wiedergegeben und die Wiedergabe dann beendet." />
    <entry _locID="play-during_auto" _locAttrData="description" value="auto" description="Der Sound des übergeordneten Elements wird weiter abgespielt." />
    <entry _locID="play-during_none" _locAttrData="description" value="none" description="Kein Hintergrundsound. Der Sound des übergeordneten Elements (falls vorhanden) wird während der Ausgabe des aktuellen Elements nicht wiedergegeben, nach dem aktuellen Element wird die Wiedergabe fortgesetzt." />
  </CssProperty>

  <CssProperty _locID="azimuth" _locAttrData="description" version="2.0" browsers="none" restriction="angle" syntax="&lt;angle&gt; | [[ left-side | far-left | left | center-left | center | center-right | right | far-right | right-side ] || behind ] | leftwards | rightwards" description="Informationen für den Raumeffekt." standard-reference="https://www.w3.org/TR/2011/REC-CSS2-20110607/aural.html#propdef-azimuth">

    <entry value="behind" />
    <entry _locID="azimuth_center" _locAttrData="description" value="center" description="Identisch mit '0deg', entspricht '180deg' bei 'behind'." />
    <entry _locID="azimuth_center-left" _locAttrData="description" value="center-left" description="Identisch mit '340deg', entspricht '200deg' bei 'behind'." />
    <entry _locID="azimuth_center-right" _locAttrData="description" value="center-right" description="Identisch mit '20deg', entspricht '160deg' bei 'behind'." />
    <entry _locID="azimuth_far-left" _locAttrData="description" value="far-left" description="Identisch mit '300deg', entspricht '240deg' bei 'behind'." />
    <entry _locID="azimuth_far-right" _locAttrData="description" value="far-right" description="Identisch mit '60deg', entspricht '120deg' bei 'behind'." />
    <entry _locID="azimuth_left" _locAttrData="description" value="left" description="Identisch mit '320deg', entspricht '220deg' bei 'behind'." />
    <entry _locID="azimuth_left-side" _locAttrData="description" value="left-side" description="Identisch mit '270deg', entspricht '270deg' bei 'behind'." />
    <entry _locID="azimuth_leftwards" _locAttrData="description" value="leftwards" description="Verschiebt die Schallquelle relativ zum aktuellen Winkel nach links. Genau genommen werden 20° abgezogen." />
    <entry _locID="azimuth_right" _locAttrData="description" value="right" description="Identisch mit '40deg', entspricht '140deg' bei 'behind'." />
    <entry _locID="azimuth_right-side" _locAttrData="description" value="right-side" description="Identisch mit '90deg', entspricht '90deg' bei 'behind'." />
    <entry _locID="azimuth_rightwards" _locAttrData="description" value="rightwards" description="Verschiebt die Schallquelle relativ zum aktuellen Winkel nach rechts. Genau genommen werden 20° hinzu addiert." />
  </CssProperty>

  <CssProperty _locID="elevation" _locAttrData="description" version="2.0" browsers="none" restriction="angle" syntax="&lt;angle&gt; | below | level | above | higher | lower" description="Informationen für den Raumeffekt." standard-reference="https://www.w3.org/TR/2011/REC-CSS2-20110607/aural.html#propdef-elevation">

    <entry _locID="elevation_below" _locAttrData="description" value="below" description="Identisch mit '-90deg'." />
    <entry _locID="elevation_level" _locAttrData="description" value="level" description="Identisch mit '0deg'." />
    <entry _locID="elevation_above" _locAttrData="description" value="above" description="Identisch mit '90deg'." />
    <entry _locID="elevation_higher" _locAttrData="description" value="higher" description="Addiert 10° zum aktuellen Raumeffekt in der Vertikalen hinzu." />
    <entry _locID="elevation_lower" _locAttrData="description" value="lower" description="Subtrahiert 10° vom aktuellen Raumeffekt in der Vertikalen." />
  </CssProperty>

  <CssProperty _locID="speech-rate" _locAttrData="description" version="2.0" browsers="none" restriction="number" description="Steuert die Sprechgeschwindigkeit. Die normale Geschwindigkeit einer Stimme hängt von der Sprache und dem Dialekt sowie von der Persönlichkeit des Sprechers ab." syntax="&lt;number&gt; | x-slow | slow | medium | fast | x-fast | faster | slower" standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-speech-rate">

    <entry _locID="speech-rate_x-slow" _locAttrData="description" value="x-slow" description="Entspricht 80 Wörtern pro Minute." />
    <entry _locID="speech-rate_slow" _locAttrData="description" value="slow" description="Entspricht 120 Wörtern pro Minute." />
    <entry _locID="speech-rate_medium" _locAttrData="description" value="medium" description="Entspricht 180-200 Wörtern pro Minute." />
    <entry _locID="speech-rate_fast" _locAttrData="description" value="fast" description="Entspricht 300 Wörtern pro Minute." />
    <entry _locID="speech-rate_x-fast" _locAttrData="description" value="x-fast" description="Entspricht 500 Wörtern pro Minute." />
    <entry _locID="speech-rate_faster" _locAttrData="description" value="faster" description="Addiert 40 Wörter pro Minute zur aktuellen Sprechgeschwindigkeit hinzu." />
    <entry _locID="speech-rate_slower" _locAttrData="description" value="slower" description="Subtrahiert 40 Wörter pro Minute von der aktuellen Sprechgeschwindigkeit." />
  </CssProperty>

  <CssProperty _locID="pitch" _locAttrData="description" version="2.0" browsers="none" restriction="frequency" description="Gibt die durchschnittliche Tonhöhe (Frequenz) der Sprecherstimme an. Die durchschnittliche Tonhöhe einer Stimme hängt von der Stimmfamilie ab. Beispielsweise liegt die durchschnittliche Tonhöhe bei einer normalen männlichen Stimme bei etwa 120 Hz und bei einer weiblichen Stimme bei etwa 210 Hz." syntax="&lt;frequency&gt; | x-low | low | medium | high | x-high" standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-pitch">

    <entry value="x-low" />
    <entry value="low" />
    <entry _locID="pitch_medium" _locAttrData="description" value="medium" description="Entspricht 100 % und steht für eine normale Tonlage." />
    <entry value="high" />
    <entry value="x-high" />
  </CssProperty>

  <CssProperty _locID="pitch-range" _locAttrData="description" version="2.0" browsers="none" restriction="number" description="Gibt Variationen in der durchschnittlichen Stimmhöhe an. Die wahrgenommene Tonhöhe einer menschlichen Stimme wird durch die grundlegende Frequenz bestimmt und liegt bei einer männlichen Stimme normalerweise bei 120 Hz und bei einer weiblichen Stimme bei 210 Hz." syntax="&lt;number&gt;" standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-pitch-range" />

  <CssProperty _locID="stress" _locAttrData="description, syntax" version="2.0" browsers="none" restriction="number(0-100)" syntax="Ein Wert zwischen '0' und '100'. Die Bedeutung dieses Werts ist abhängig von der eingestellten Sprache. Der Wert '50' hat auf eine durchschnittliche männliche deutsche Stimme (durchschnittliche Tonhöhe = 122 Hz), die mit normaler Intonation und Betonung gesprochen wird, eine andere Wirkung als der Wert '50' bei einer italienischen Stimme." description="Gibt die Höhe der 'lokalen Spitzen' im Intonationsverlauf einer Stimme an. Beispielsweise ist Englisch eine betonte Sprache und verschiedene Satzteile erhalten eine primäre, sekundäre oder tertiäre Betonung." standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-stress" />

  <CssProperty _locID="richness" _locAttrData="description, syntax" version="2.0" browsers="none" restriction="number(0-100)" syntax="Ein Wert zwischen '0' und '100'. Je höher der Wert, desto weiter trägt die Stimme. Niedrige Werte bezeichnen eine weiche, einschmeichelnde Stimme." description="Gibt die Sättigung oder Klangfülle der Sprecherstimme an. Eine harsche Stimme kann sich in einem großen Raum leichter durchsetzen als eine weiche Stimme." standard-reference="https://www.w3.org/TR/CSS2/aural.html#propdef-richness" />

