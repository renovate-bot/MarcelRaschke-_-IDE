<CssModule name="Speech" standard-reference="https://www.w3.org/TR/css-speech-1/" status="CR" pub-date="2020-03-10">

  <CssProperty _locID="voice-volume" _locAttrData="description" version="3.0" browsers="none" restriction="volume, enum" description="Bezieht sich auf die Amplitude der Waveformausgabe eines Sprachsynthesizers. Der Wert 'silent' ist '0' und 'x-loud' ist '100' zugeordnet. Die Zuordnung anderer Werte zu numerischen Lautstärkestufen ist von der Implementierung abhängig und kann je nach Sprachsynthesizer variieren." syntax="&lt;decibel&gt; | silent | x-soft | soft | medium | loud | x-loud" standard-reference="https://www.w3.org/TR/css-speech-1/#voice-volume">

    <entry _locID="voice-volume_silent" _locAttrData="description" value="silent" description="Der Lautstärkewert 0." />
    <entry value="x-soft" />
    <entry value="soft" />
    <entry value="medium" />
    <entry value="loud" />
    <entry _locID="voice-volume_x-loud" _locAttrData="description" value="x-loud" description="Der Lautstärkewert 100." />
  </CssProperty>

  <CssProperty _locID="voice-balance" _locAttrData="description" version="3.0" browsers="none" restriction="number(-100-100)" description="Bezieht sich auf die Balance zwischen linkem und rechtem Kanal und setzt die Verwendung eines 2-Kanal-Modells (stereo) voraus, das von Audiogeräten in der Regel unterstützt wird." syntax="&lt;number&gt; | left | center | right | leftwards | rightwards" standard-reference="https://www.w3.org/TR/css-speech-1/#voice-balance">

    <entry _locID="voice-balance_left" _locAttrData="description" value="left" description="Identisch mit -100." />
    <entry _locID="voice-balance_center" _locAttrData="description" value="center" description="Identisch mit '0'." />
    <entry _locID="voice-balance_right" _locAttrData="description" value="right" description="Identisch mit '100' oder '+100." />
    <entry _locID="voice-balance_leftwards" _locAttrData="description" value="leftwards" description="Verschiebt den Sound relativ zum geerbten 'voice-balance'-Wert nach links. Genauer gesagt wird 20 vom geerbten Wert subtrahiert und der resultierende Wert an '-100' und '100' angeheftet." />
    <entry _locID="voice-balance_rightwards" _locAttrData="description" value="rightwards" description="Verschiebt den Sound relativ zum geerbten 'voice-balance'-Wert nach rechts. Genauer gesagt wird 20 zum geerbten Wert hinzu addiert und der resultierende Wert an '-100' und '100' angeheftet." />
  </CssProperty>

  <CssProperty _locID="speak" _locAttrData="description" version="2.0" browsers="none" restriction="enum" syntax="div { $(name): normal; }" description="Gibt an, ob Text akustisch ausgegeben wird, und falls ja, auf welche Weise dies geschieht." standard-reference="https://www.w3.org/TR/css-speech-1/#speak">

    <entry _locID="speak_auto" _locAttrData="description" value="auto" description="Wird in den berechneten Wert &quot;nie&quot; aufgelöst, wenn &quot;anzeigen&quot; den Wert &quot;kein&quot; aufweist, andernfalls wird er in den berechneten Wert &quot;auto&quot; aufgelöst. Der verwendete Wert entspricht dann &quot;immer&quot;, wenn &quot;Sichtbarkeit&quot; &quot;sichtbar&quot; ist, andernfalls &quot;nie&quot;." />
    <entry _locID="speak_never" _locAttrData="description" value="never" description="Dieser Wert bewirkt, dass ein Element (einschließlich Pausen, Hinweisen, Ruhezeiten und tatsächlichem Inhalt) nicht gerendert wird (d. h., das Element hat keine Auswirkungen auf die akustische Dimension)." />
    <entry _locID="speak_always" _locAttrData="description" value="always" description="Das Element wird akustisch gerendert (unabhängig von seinem Wert &quot;anzeigen&quot; oder den Werten &quot;anzeigen&quot; oder &quot;sprechen&quot; seiner Vorgänger)." />
  </CssProperty>

  <CssProperty _locID="speak-as" _locAttrData="description" version="3.0" browsers="none" restriction="enum" syntax="div { $(name): spell-out; }" description="Legt auf Basis einer vordefinierten Werteliste fest, wie Text akustisch ausgegeben wird." standard-reference="https://www.w3.org/TR/css-speech-1/#speak-as">

    <entry _locID="speak-as_normal" _locAttrData="description" value="normal" description="Verwendet sprachabhängige Ausspracheregeln für die Wiedergabe des Elementinhalts." />
    <entry _locID="speak-as_spell-out" _locAttrData="description" value="spell-out" description="Buchstabiert den Text Buchstabe für Buchstabe (hilfreich für Akronyme und Abkürzungen)." />
    <entry _locID="speak-as_digits" _locAttrData="description" value="digits" description="Gibt Zahlen Ziffer für Ziffer wieder, z.B. wird 'zwölf' als 'eins zwei' ausgegeben und '31' als 'drei eins'." />
    <entry _locID="speak-as_literal-punctuation" _locAttrData="description" value="literal-punctuation" description="Satzzeichen wie Semikolons, Klammern usw. werden (Zeichen für Zeichen) mitgesprochen, anstatt natürliche Sprechpausen einzulegen." />
    <entry _locID="speak-as_no-punctuation" _locAttrData="description" value="no-punctuation" description="Satzzeichen werden nicht ausgegeben, weder gesprochen noch als Sprechpausen." />
  </CssProperty>

  <CssPropertyValue type="pause-time">
    <entry value="none" />
    <entry value="x-weak" />
    <entry value="weak" />
    <entry value="medium" />
    <entry value="strong" />
    <entry value="x-strong" />
  </CssPropertyValue>

  <CssProperty _locID="pause-before" _locAttrData="description" version="2.0" browsers="none" restriction="time" description="Gibt eine Pause oder prosodische Grenze an, die vor einem Element beachtet werden soll, bzw. vor einem 'cue-before', falls diese Eigenschaft angegeben ist. Die Werte geben die prosodische Stärke der Sprechpause an." syntax="h3 { $(name): 30ms; }" standard-reference="https://www.w3.org/TR/css-speech-1/#pause-before" type="pause-time" />

  <CssProperty _locID="pause-after" _locAttrData="description" ref="pause-before" version="2.0" browsers="none" description="Gibt eine Pause oder prosodische Grenze an, die nach einem Element beachtet werden soll, bzw. nach einem 'cue-before', falls diese Eigenschaft angegeben ist. Die Werte geben die prosodische Stärke der Sprechpause an." standard-reference="https://www.w3.org/TR/css-speech-1/#pause-after" />

  <CssProperty _locID="pause" _locAttrData="description" version="2.0" browsers="none" restriction="time, enum" type="pause-time" description="Kurzschreibweise zum Festlegen von 'pause-before' und 'pause-after'. Wenn zwei Werte angegeben sind, entspricht der erste Wert 'pause-before' und der zweite 'pause-after'. Wenn nur ein Wert angegeben ist, gilt dieser für beide Eigenschaften." syntax="h2 { $(name): 30ms 40ms; }" standard-reference="https://www.w3.org/TR/css-speech-1/#pause" />


  <CssProperty _locID="rest-before" _locAttrData="description" version="3.0" browsers="none" type="pause-time" restriction="time" description="Gibt eine Sprechpause oder prosodische Grenze an, die vor dem Inhalt eines Elements beachtet werden soll." syntax="h3 { $(name): 4s; }" standard-reference="https://www.w3.org/TR/css-speech-1/#rest-before" />

  <CssProperty _locID="rest-after" _locAttrData="description" ref="rest-before" description="Gibt eine Sprechpause oder prosodische Grenze an, die nach dem Inhalt eines Elements beachtet werden soll." standard-reference="https://www.w3.org/TR/css-speech-1/#rest-after" />

  <CssProperty _locID="rest" _locAttrData="description" ref="rest-before" description="Kurzschreibweise zum Festlegen von 'rest-before' und 'rest-after'. Wenn zwei Werte angegeben sind, entspricht der erste Wert 'rest-before' und der zweite 'rest-after'. Wenn nur ein Wert angegeben ist, gilt dieser für beide Eigenschaften." standard-reference="https://www.w3.org/TR/css-speech-1/#rest" />

  <CssProperty _locID="cue-before" _locAttrData="description" version="2.0" browsers="none" restriction="url, volume, enum" type="url" description="Akustiksymbole sind eine weitere Möglichkeit zur Unterscheidung semantischer Elemente. Die Signale können vor und/oder nach dem Element wiedergegeben werden, um es abzugrenzen." syntax="h1 { $(name): url(dong.wav) -3dB;}" standard-reference="https://www.w3.org/TR/css-speech-1/#cue-before">

    <entry _locID="cue-before_" _locAttrData="description" value="none" description="Es ist kein Akustiksymbol angegeben." />
  </CssProperty>

  <CssProperty _locID="cue-after" ref="cue-before" standard-reference="https://www.w3.org/TR/css-speech-1/#cue-after" />

  <CssProperty _locID="cue" _locAttrData="description" ref="cue-before" description="Kurzschreibweise zum Festlegen von 'cue-before' und 'cue-after'. Wenn zwei Werte angegeben sind, entspricht der erste Wert 'cue-before' und der zweite 'cue-after'. Wenn nur ein Wert angegeben ist, gilt dieser für beide Eigenschaften.." standard-reference="https://www.w3.org/TR/css-speech-1/#cue" />

  <CssProperty _locID="voice-family" _locAttrData="description" version="2.0" browsers="none" restriction="number, string" syntax="[[&lt;specific-voice&gt; | &lt;generic-voice&gt; ],]* [&lt;specific-voice&gt; | &lt;generic-voice&gt; ]" description="Durch Trennzeichen getrennte Prioritätsliste der Namen von Stimmtypen (vgl. 'font-family')." standard-reference="https://www.w3.org/TR/css-speech-1/#voice-family">

    <entry _locID="voice-family_neutral" _locAttrData="description" value="neutral" description="Neutrale Stimme für 'generic-voice'." />
    <entry _locID="voice-family_male" _locAttrData="description" value="male" description="Männliche Stimme für 'generic-voice'." />
    <entry _locID="voice-family_female" _locAttrData="description" value="female" description="Weibliche Stimme für 'generic-voice'." />

    <entry _locID="voice-family_child" _locAttrData="description" value="child" description="Kinderstimme für &quot;Alter&quot;" />
    <entry _locID="voice-family_young" _locAttrData="description" value="young" description="Stimme einer jungen Person für &quot;Alter&quot;" />
    <entry _locID="voice-family_old" _locAttrData="description" value="old" description="Stimme einer älteren Person für &quot;Alter&quot;" />

    <entry _locID="voice-family_preserve" _locAttrData="description" value="preserve" description="Gibt an, dass der Wert &quot;Sprachfamilie&quot; unabhängig von möglichen Sprachänderungen im Inhaltsmarkup geerbt und verwendet wird (siehe Abschnitt unten zur Sprachauswahl und Sprachbehandlung)." />
  </CssProperty>

  <CssProperty _locID="voice-rate" _locAttrData="description" version="3.0" browsers="none" restriction="percentage" description="Steuert die Sprechgeschwindigkeit. Die normale Geschwindigkeit einer Stimme hängt von der Sprache und dem Dialekt sowie von der Persönlichkeit des Sprechers ab." syntax="&lt;percentage&gt; | x-slow | slow | medium | fast | x-fast" standard-reference="https://www.w3.org/TR/css-speech-1/#voice-rate">

    <entry value="normal" />
    <entry value="x-slow" />
    <entry value="slow" />
    <entry _locID="voice-rate_medium" _locAttrData="description" value="medium" description="Entspricht 100 %, der normalen Sprechgeschwindigkeit für diese Stimme." />
    <entry value="fast" />
    <entry value="x-fast" />
  </CssProperty>

  <CssProperty _locID="voice-pitch" _locAttrData="description" version="3.0" browsers="none" restriction="percentage, number, frequency, semitones" syntax="h2 { $(name): absolute 30Hz; }" description="Gibt die durchschnittliche Tonhöhe (Frequenz) der Sprecherstimme an. Die durchschnittliche Tonhöhe einer Stimme hängt von der Stimmfamilie ab. Beispielsweise liegt die durchschnittliche Tonhöhe bei einer normalen männlichen Stimme bei etwa 120 Hz und bei einer weiblichen Stimme bei etwa 210 Hz." standard-reference="https://www.w3.org/TR/css-speech-1/#voice-pitch">

    <entry value="absolute" />
    <entry value="x-low" />
    <entry value="low" />
    <entry _locID="voice-pitch_medium" _locAttrData="description" value="medium" description="Entspricht 100 % und steht für eine normale Tonlage." />
    <entry value="high" />
    <entry value="x-high" />
  </CssProperty>

  <CssProperty _locID="voice-range" _locAttrData="description" version="3.0" browsers="none" restriction="percentage, number, frequency, semitones" syntax="h2 { $(name): +10Hz; }" description="Gibt die Abweichung in der durchschnittlichen Tonhöhe an. Die menschliche Sprache weist Abweichungen im Tonfall und in der Tonhöhe auf; diese dienen dazu, eine zusätzliche Bedeutung oder Betonung zu vermitteln." standard-reference="https://www.w3.org/TR/css-speech-1/#voice-props-voice-range">

    <entry value="absolute" />
    <entry value="x-low" />
    <entry value="low" />
    <entry value="medium" />
    <entry value="high" />
    <entry value="x-high" />
  </CssProperty>

  <CssProperty _locID="voice-stress" _locAttrData="description" version="3.0" browsers="none" restriction="enum" syntax="h2 { $(name): moderate; }" description="Gibt die anzuwendende Betonungsstärke an. Die Betonung ergibt sich aus einer Kombination folgender Faktoren: geänderte Tonhöhe, Timingwechsel, Abweichungen bei Lautstärke und anderen akustischen Merkmalen. Diese sind je nach Sprache unterschiedlich." standard-reference="https://www.w3.org/TR/css-speech-1/#voice-stress">

    <entry _locID="voice-stress_none" _locAttrData="description" value="none" description="Verhindert eine Betonung von Wörtern, die vom Synthesizer normalerweise betont werden." />
    <entry value="normal" />
    <entry value="moderate" />
    <entry value="strong" />
    <entry _locID="voice-stress_reduced" _locAttrData="description" value="reduced" description="Der Gegensatz zur Betonung eines Worts. Wenn beispielsweise die Betonung von 'Hör einmal' reduziert wird, lautet das gesprochene Ergebnis 'Hörmal'." />
  </CssProperty>

  <CssProperty _locID="voice-duration" _locAttrData="description" version="3.0" browsers="none" restriction="time" description="Autoren können festlegen, wie lange es dauern soll, den Inhalt des ausgewählten Elements auszugeben. Diese Eigenschaft überschreibt die 'voice-rate'-Eigenschaft." syntax="&lt;time&gt;" standard-reference="https://www.w3.org/TR/css-speech-1/#voice-duration">
    <entry value="auto" />
  </CssProperty>

