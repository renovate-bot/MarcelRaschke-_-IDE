<CssModule name="Selectors" standard-reference="https://www.w3.org/TR/selectors-4/" status="WD" pub-date="2018-11-21">

  <CssPseudo name=":is(:hover)" _locID="is-pseudo-element" _locAttrData="description" syntax=":is(ul, ol, .list) &gt; [hidden] { text-decoration: none; }" description="The matches-any pseudo-class, :is(), is a functional pseudo-class taking a selector list as its argument. It represents an element that is represented by its argument." standard-reference="https://www.w3.org/TR/selectors-4/#matches" />

  <CssPseudo name=":not(:empty)" _locID="not-pseudo-class" _locAttrData="description" browsers="C,FF1,IE9,O9.5,S2" syntax="div:not(:empty) { border-color: pink; }" description="Die 'negation'-Pseudoklasse ':not(X)' ist eine Funktionsschreibweise, die einen einfachen Selektor (mit Ausnahme der 'negation'-Pseudoklasse selbst) als Argument akzeptiert. Sie stellt ein Element dar, das nicht durch sein Argument repräsentiert wird." standard-reference="https://www.w3.org/TR/selectors-4/#negation" />

  <CssPseudo name=":where(:hover)" _locID="where-pseudo-class" _locAttrData="description" browsers="none" syntax="div:where(:hover) { border-color: pink; }" description="The Specificity-adjustment pseudo-class, :where(), is a functional pseudo-class with the same syntax and functionality as :is(). Unlike :is(), neither the :where pseudo-class, nor any of its arguments contribute to the specificity of the selector—its specificity is always zero." standard-reference="https://www.w3.org/TR/selectors-4/#zero-matches" />

  <CssPseudo name=":defined" _locID="defined-pseudo-class" _locAttrData="description" syntax="custom-element:not(:defined) { display: none; }" description="In some host languages, elements can have a distinction between being “defined”/“constructed” or not. The :defined pseudo-class matches elements that are fully defined, as dictated by the host language. Custom elements, for example, start out undefined, and only become defined when properly registered." standard-reference="https://drafts.csswg.org/selectors/#the-defined-pseudo" />

  <CssPseudo name=":has(:hover)" _locID="has-pseudo-class" _locAttrData="description" browsers="none" syntax="div:matches(:hover) { border-color: pink; }" description="The relational pseudo-class, :has(), is a functional pseudo-class taking a relative selector list as an argument. It represents an element if any of the relative selectors, when absolutized and evaluated with the element as the :scope elements, would match at least one element." standard-reference="https://www.w3.org/TR/selectors-4/#relational" />

  <CssPseudo name=":dir(ltr)" _locID="dir-pseudo-class" _locAttrData="description" browsers="none" syntax="section:dir(ltr) { border-color: pink; }" description="Die Pseudoklasse &quot;:dir()&quot; ermöglicht dem Ersteller das Schreiben von Selektoren, die ein Element basierend auf seiner Richtung darstellen, die von der Dokumentsprache bestimmt wird." standard-reference="https://www.w3.org/TR/selectors-4/#the-dir-pseudo" />

  <CssPseudo name=":lang(en)" _locID="lang-pseudo-function" _locAttrData="description" browsers="C,FF1,IE8,O8,S3" syntax="html:lang(en) { color: blue; }" description="Die ':lang(C)'-Pseudoklasse stellt ein Element dar, das in der Programmiersprache C geschrieben ist." standard-reference="https://www.w3.org/TR/selectors-4/#the-lang-pseudo" />

  <CssPseudo name=":any-link" syntax="a:any-link { text-decoration: none; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-any-link-pseudo" />

  <CssPseudo name=":link" _locID="link-pseudo-element" _locAttrData="description" syntax="a:link { text-decoration: none; }" description="Die ':link'-Pseudoklasse wird auf Links angewendet, die noch nicht aktiviert wurden." standard-reference="https://www.w3.org/TR/selectors-4/#link" />

  <CssPseudo name=":visited" _locID="visited-pseudo-element" _locAttrData="description" syntax="a:visited { color: purple; }" description="Die ':visited'-Pseudoklasse wird angewendet, sobald der Link vom Benutzer aktiviert wurde." standard-reference="https://www.w3.org/TR/selectors-4/#link" />

  <CssPseudo name=":local-link" syntax="a:local-link { text-decoration: none; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-local-link-pseudo" />

  <CssPseudo name=":target" _locID="target-pseudo-class" _locAttrData="description" syntax="h2:target { background-color: yellow; }" description="Einige URIs verweisen auf einen Ort innerhalb einer Ressource. Diese URIs enden mit einem 'Nummernzeichen' (#), gefolgt von einem Ankerbezeichner (dem so genannten Fragmentbezeichner)." standard-reference="https://www.w3.org/TR/selectors-4/#the-target-pseudo" />

  <CssPseudo name=":target-within" _locID="target-within-pseudo-class" _locAttrData="description" syntax="h2:target { background-color: yellow; }" description="The :target-within pseudo-class applies to elements for which the :target pseudo class applies as well as to an element whose descendant in the flat tree (including non-element nodes, such as text nodes) matches the conditions for matching :target-within." standard-reference="https://www.w3.org/TR/selectors-4/#the-target-within-pseudo" />

  <CssPseudo name=":scope" _locID="scope-pseudo-class" _locAttrData="description" syntax=":scope { border-color: pink; }" description="Die Pseudoklasse &quot;:scope&quot; stellt ein beliebiges Element dar, das in der kontextuellen Verweiselementsammlung enthalten ist." standard-reference="https://www.w3.org/TR/selectors-4/#the-scope-pseudo" />

  <CssPseudo name=":hover" _locID="hover-pseudo-element" _locAttrData="description" syntax="a:hover { text-decoration: none; }" description="Die ':hover'-Pseudoklasse wird angewendet, während der Benutzer ein Element mit einem Zeigegerät ansteuert, aber nicht unbedingt aktiviert. Ein visueller Benutzer-Agent könnte die Pseudoklasse beispielsweise anwenden, wenn der Cursor (Mauszeiger) über eine Box bewegt wird, die vom Element erzeugt wurde." standard-reference="https://www.w3.org/TR/selectors-4/#the-hover-pseudo" />

  <CssPseudo name=":active" _locID="active-pseudo-element" _locAttrData="description" syntax="a:active { color: red; }" description="Die ':active'-Pseudoklasse wird angewendet, während ein Element vom Benutzer aktiviert wird, z.B. in der Zeit zwischen dem Drücken und Loslassen der Maustaste." standard-reference="https://www.w3.org/TR/selectors-4/#the-active-pseudo" />

  <CssPseudo name=":focus" _locID="focus-pseudo-element" _locAttrData="description" syntax="a:focus { color: yellow; }" description="Die ':focus'-Pseudoklasse wird angewendet, während ein Element den Fokus besitzt (Tastatur- oder Mausereignisse oder andere Eingabemethoden)." standard-reference="https://www.w3.org/TR/selectors-4/#the-focus-pseudo" />

  <CssPseudo name=":focus-visible" _locID="focus-visible-pseudo-element" _locAttrData="description" syntax="a:focus-visible { color: yellow; }" description="Die Pseudoklasse &quot;:focus-visible&quot; gilt, wenn ein Element mit der Pseudoklasse &quot;:focus&quot; übereinstimmt und der Benutzer-Agent per Heuristik bestimmt, dass der Fokus auf dem Element deutlich gemacht werden soll." standard-reference="https://www.w3.org/TR/selectors-4/#the-focus-visible-pseudo" />

  <CssPseudo name=":focus-within" _locID="focus-within-pseudo-element" _locAttrData="description" syntax="a:focus-within { color: yellow; }" description="Die Pseudoklasse &quot;:focus-within&quot; gilt für alle Elemente, für die die Pseudoklasse &quot;:focus&quot; gilt, sowie für Elemente, deren Nachfolger in der flachen Struktur (einschließlich Nicht-Element-Knoten wie beispielsweise Textknoten) die Bedingungen für die Übereinstimmung mit &quot;:focus&quot; erfüllen." standard-reference="https://www.w3.org/TR/selectors-4/#the-focus-within-pseudo" />

  <CssPseudo name=":current" syntax=":current { text-decoration: none; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-current-pseudo" />

  <CssPseudo name=":current(div)" syntax=":current(div, p) { color: blue; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-current-pseudo" />

  <CssPseudo name=":past" syntax=":past { color: green; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-past-pseudo" />

  <CssPseudo name=":future" syntax=":future { color: yellow; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-future-pseudo" />

  <CssPseudo name=":playing" syntax=":playing { border: 5px solid green; }" standard-reference="https://www.w3.org/TR/selectors-4/#video-state" />

  <CssPseudo name=":paused" syntax=":paused { border: 5px solid yellow; }" standard-reference="https://www.w3.org/TR/selectors-4/#video-state" />

  <CssPseudo name=":enabled" _locID="enabled-pseudo-class" _locAttrData="description" version="3.0" browsers="C,FF1.5,IE9,O9,S3.1" syntax="input:enabled { background-color: green; }" description="Die ':enabled'-Pseudoklasse stellt Benutzeroberflächenelemente dar, die sich in einem aktivierten Zustand befinden; die Elemente verfügen dementsprechend auch über einen deaktivierten Zustand." standard-reference="https://www.w3.org/TR/selectors-4/#enableddisabled" />

  <CssPseudo name=":disabled" _locID="disabled-pseudo-class" _locAttrData="description" version="3.0" browsers="C,FF1.5,IE9,O9,S3.1" syntax="input:disabled { background-color: silver; }" description="Die ':disabled'-Pseudoklasse stellt Benutzeroberflächenelemente darf, die sich in einem deaktivierten Zustand befinden; die Elemente verfügen dementsprechend auch über einen aktivierten Zustand." standard-reference="https://www.w3.org/TR/selectors-4/#enableddisabled" />

  <CssPseudo name=":read-only" syntax=":read-only { color: gray; }" standard-reference="https://www.w3.org/TR/selectors-4/#rw-pseudos" />

  <CssPseudo name=":read-write" syntax=":read-write { color: black; }" standard-reference="https://www.w3.org/TR/selectors-4/#rw-pseudos" />

  <CssPseudo name=":placeholder-shown" syntax=":placeholder-shown { border: 2px solid silver; }" standard-reference="https://www.w3.org/TR/selectors-4/#placeholder" />

  <CssPseudo name=":default" syntax="input:default { box-shadow: 0 0 2px 1px coral; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-default-pseudo" />

  <CssPseudo name=":checked" _locID="checked-pseudo-class" _locAttrData="description" syntax="input:checked { color: red; }" description="Optionsfelder und Kontrollkästchen können vom Benutzer ein-/ausgeschaltet werden. Einige Menüelemente sind 'aktiviert', wenn sie vom Benutzer ausgewählt werden. Die ':checked'-Pseudoklasse wird angewendet, wenn diese Elemente eingeschaltet (aktiviert) werden." standard-reference="https://www.w3.org/TR/selectors-4/#checked" />

  <CssPseudo name=":indeterminate" _locID="indeterminate-pseudo-class" _locAttrData="description" syntax="input:indeterminate { color: yellow; }" description="The :indeterminate pseudo-class applies to UI elements whose value is in an indeterminate state. For example, radio and checkbox elements can be toggled between checked and unchecked states, but are sometimes in an indeterminate state, neither checked nor unchecked." standard-reference="https://www.w3.org/TR/selectors-4/#indeterminate" />

  <CssPseudo name=":blank" _locID="blank-pseudo-class" _locAttrData="description" syntax="input:blank { border: 1px solid red; }" description="The :blank pseudo-class applies to user-input elements whose input value is empty (consists of the empty string or otherwise null input)." standard-reference="https://www.w3.org/TR/selectors-4/#blank" />

  <CssPseudo name=":valid" _locID="valid-pseudo-class" _locAttrData="description" syntax="input:valid { border: 1px solid green; }" description="An element is :valid or :invalid when its contents or value is, respectively, valid or invalid with respect to data validity semantics defined by the document language (e.g. [XFORMS11] or [HTML5]). An element which lacks data validity semantics is neither :valid nor :invalid." standard-reference="https://www.w3.org/TR/selectors-4/#validity-pseudos" />

  <CssPseudo name=":invalid" _locID="invalid-pseudo-class" _locAttrData="description" syntax="input:invalid { color: red; }" description="An element is :valid or :invalid when its contents or value is, respectively, valid or invalid with respect to data validity semantics defined by the document language (e.g. [XFORMS11] or [HTML5]). An element which lacks data validity semantics is neither :valid nor :invalid." standard-reference="https://www.w3.org/TR/selectors-4/#validity-pseudos" />

  <CssPseudo name=":in-range" _locID="in-range-pseudo-class" _locAttrData="description" syntax="input:in-range { border: 1px solid green; }" description="The :in-range and :out-of-range pseudo-classes apply only to elements that have range limitations. An element is :in-range or :out-of-range when the value that the element is bound to is in range or out of range with respect to its range limits as defined by the document language. An element that lacks data range limits or is not a form control is neither :in-range nor :out-of-range." standard-reference="https://www.w3.org/TR/selectors-4/#range-pseudos" />

  <CssPseudo name=":out-of-range" _locID="out-of-range-pseudo-class" _locAttrData="description" syntax="input:out-of-range { color: red; }" description="The :in-range and :out-of-range pseudo-classes apply only to elements that have range limitations. An element is :in-range or :out-of-range when the value that the element is bound to is in range or out of range with respect to its range limits as defined by the document language. An element that lacks data range limits or is not a form control is neither :in-range nor :out-of-range." standard-reference="https://www.w3.org/TR/selectors-4/#range-pseudos" />

  <CssPseudo name=":required" _locID="required-pseudo-class" _locAttrData="description" syntax="input:required { border: 1px solid coral; }" description="A form element is :required or :optional if a value for it is, respectively, required or optional before the form it belongs to can be validly submitted. Elements that are not form elements are neither required nor optional." standard-reference="https://www.w3.org/TR/selectors-4/#opt-pseudos" />

  <CssPseudo name=":optional" _locID="optional-pseudo-class" _locAttrData="description" syntax="input:optional { border: 1px solid gray; }" description="A form element is :required or :optional if a value for it is, respectively, required or optional before the form it belongs to can be validly submitted. Elements that are not form elements are neither required nor optional." standard-reference="https://www.w3.org/TR/selectors-4/#opt-pseudos" />

  <CssPseudo name=":user-invalid" _locID="user-invalid-pseudo-class" _locAttrData="description" syntax="input:user-invalid { border: 1px solid red; }" description="The :user-invalid pseudo-class represents an element with incorrect input, but only after the user has significantly interacted with it." standard-reference="https://www.w3.org/TR/selectors-4/#user-pseudos" />

  <CssPseudo name=":root" _locID="root-pseudo-class" _locAttrData="description" syntax=":root { padding: auto 3em; }" description="Die ':root'-Pseudoklasse stellt ein Element dar, das das Stammelement des Dokuments ist. In HTML 4 handelt es sich dabei immer um das HTML-Element." standard-reference="https://www.w3.org/TR/selectors-4/#the-root-pseudo" />

  <CssPseudo name=":empty" _locID="empty-pseudo-class" _locAttrData="description" syntax="div:empty { background-color: red; }" description="Die ':empty'-Pseudoklasse stellt ein Element dar, das überhaupt keine untergeordneten Elemente aufweist." standard-reference="https://www.w3.org/TR/selectors-4/#the-empty-pseudo" />

  <CssPseudo name=":nth-child(2n+1)" _locID="nth-child-pseudo-class" _locAttrData="description" syntax="tr:nth-child(2n+1) { border-color: pink; }" description="Die Schreibweise der ':nth-child(an+b)'-Pseudoklasse stellt ein Element dar, das für jede positive ganze Zahl oder den Nullwert von 'n' über vorangestellte, gleichgeordnete an+b-1-Elemente in der Dokumentstruktur verfügt und ein übergeordnetes Element aufweist." standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-child-pseudo" />

  <CssPseudo name=":nth-last-child(-n+2)" _locID="nth-last-child-pseudo-class" _locAttrData="description" syntax="tr:nth-last-child(-n+2) { border-color: pink; }" description="Die Schreibweise der :nth-last-child(an+b)'-Pseudoklasse stellt ein Element dar, das für jede positive ganze Zahl oder den Nullwert von 'n' über nachgestellte, gleichgeordnete an+b-1-Elemente in der Dokumentstruktur verfügt und ein übergeordnetes Element aufweist." standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-last-child-pseudo" />

  <CssPseudo name=":first-child" _locID="first-child-pseudo-class" _locAttrData="description" syntax="li:first-child { font-size: 1.2em; }" description="Identisch mit ':nth-child(1)'. Die ':first-child'-Pseudoklasse stellt ein Element dar, das dem ersten untergeordneten Element eines anderen Elements entspricht." standard-reference="https://www.w3.org/TR/selectors-4/#the-first-child-pseudo" />

  <CssPseudo name=":last-child" _locID="last-child-pseudo-class" _locAttrData="description" syntax="li:last-child { font-size: 1.2em; }" description="Identisch mit ':nth-last-child(1)'. Die ':last-child'-Pseudoklasse stellt ein Element dar, das dem letzten untergeordneten Element eines anderen Elements entspricht." standard-reference="https://www.w3.org/TR/selectors-4/#the-last-child-pseudo" />

  <CssPseudo name=":only-child" _locID="only-child-pseudo-class" _locAttrData="description" syntax="p:only-child { color: #f00; }" description="Stellt ein Element dar, das über ein übergeordnetes Element verfügt, das keine weiteren untergeordneten Elemente aufweist. Identisch mit ':first-child:last-child' oder ':nth-child(1):nth-last-child(1)', jedoch mit einer niedrigeren Detailgenauigkeit." standard-reference="https://www.w3.org/TR/selectors-4/#the-only-child-pseudo" />

  <CssPseudo name=":nth-of-type(2n+1)" _locID="nth-of-type-pseudo-class" _locAttrData="description" syntax="tr:nth-of-type(2n) { border-color: pink; }" description="Die Schreibweise der ':nth-of-type(an+b)'-Pseudoklasse stellt ein Element dar, das für jede Null oder positive ganze Zahl von 'n' über vorangestellte, gleichgeordnete an+b-1-Elemente mit demselben erweiterten Elementnamen in der Dokumentstruktur verfügt und ein übergeordnetes Element aufweist." standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-of-type-pseudo" />

  <CssPseudo name=":nth-last-of-type(n+2)" _locID="nth-last-of-type-pseudo-class" _locAttrData="description" syntax="tr:nth-last-of-type(n+2) { border-color: pink; }" description="Die Schreibweise der ':nth-last-of-type(an+b)'-Pseudoklasse stellt ein Element dar, das für jede Null oder positive ganze Zahl von 'n' über nachgestellte, gleichgeordnete an+b-1-Elemente in der Dokumentstruktur verfügt und ein übergeordnetes Element aufweist." standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-last-of-type-pseudo" />

  <CssPseudo name=":first-of-type" _locID="first-of-type-pseudo-class" _locAttrData="description" version="3.0" browsers="C,FF3.5,IE9,O9.5,S3.2" syntax="dl dt:first-of-type { font-size: 200%; }" description="Identisch mit ':nth-of-type(1)'. Die ':first-of-type'-Pseudoklasse stellt ein Element dar, das dem ersten gleichgeordneten Element dieses Typs in der Liste der Elemente entspricht, die dem übergeordneten Element untergeordnet sind." standard-reference="https://www.w3.org/TR/selectors-4/#the-first-of-type-pseudo" />

  <CssPseudo name=":last-of-type" _locID="last-of-type-pseudo-class" _locAttrData="description" version="3.0" browsers="C,FF3.5,IE9,O9.5,S3.1" syntax="dl dt:last-of-type { font-size: 200%; }" description="Identisch mit ':nth-last-of-type(1)'. Die ':last-of-type'-Pseudoklasse stellt ein Element dar, das dem letzten gleichgeordneten Element seines Typs in der Liste der Elemente entspricht, die dem übergeordneten Element untergeordnet sind." standard-reference="https://www.w3.org/TR/selectors-4/#the-last-of-type-pseudo" />

  <CssPseudo name=":only-of-type" _locID="only-of-type-pseudo-class" _locAttrData="description" version="3.0" browsers="C,FF3.5,IE9,O9.5,S3.2" syntax="p:only-of-type { color: #f00; }" description="Der ':only-of-type'-Selektor vergleicht jedes Element, das das einzige untergeordnete Element seines Typs für das jeweilige übergeordnete Element ist. Identisch mit ':first-of-type:last-of-type' oder ':nth-of-type(1):nth-last-of-type(1)', jedoch mit niedrigerer Detailgenauigkeit." standard-reference="https://www.w3.org/TR/selectors-4/#the-only-of-type-pseudo" />

  <CssPseudo name=":nth-col(2n+1)" version="3.0" browsers="none" syntax=":nth-col(2n+1) &gt; span { color: yellow; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-col-pseudo" />

  <CssPseudo name=":nth-last-col(2n+1)" version="3.0" browsers="none" syntax=":nth-last-col(2n+1) &gt; span { color: yellow; }" standard-reference="https://www.w3.org/TR/selectors-4/#the-nth-last-col-pseudo" />

