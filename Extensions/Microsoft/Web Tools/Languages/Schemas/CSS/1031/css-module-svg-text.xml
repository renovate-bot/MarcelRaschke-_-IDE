<CssModule name="SVG Text" standard-reference="http://www.w3.org/TR/SVG11/text.html" status="REC" pub-date="2011-08-16">

  <CssProperty _locID="glyph-orientation-horizontal" _locAttrData="description" version="3.0" restriction="angle" description="Legt einen Wert fest, der die Ausrichtung einer Zeichenfolge im Verhältnis zu einer horizontalen 'inline-progression-direction' ändert, oder ruft diesen ab." standard-reference="http://www.w3.org/TR/SVG11/text.html#GlyphOrientationHorizontalProperty" />

  <CssProperty _locID="glyph-orientation-vertical" _locAttrData="description" version="3.0" restriction="angle, enum" description="Legt einen Wert fest, der die Ausrichtung einer Zeichenfolge im Verhältnis zu einer vertikalen 'inline-progression-direction' ändert, oder ruft diesen ab." standard-reference="http://www.w3.org/TR/SVG11/text.html#GlyphOrientationVerticalProperty">

    <entry _locID="glyph-orientation-vertical_auto" _locAttrData="description" value="auto" description="Legt die Ausrichtung basierend auf Zeichen voller Breite bzw. geringerer Breite und der gebräuchlichsten Ausrichtung fest." />
  </CssProperty>

  <CssProperty _locID="kerning" _locAttrData="description" version="3.0" restriction="length, enum" description="Gibt an, ob die Abstände zwischen Glyphen vom Benutzer-Agent auf der Grundlage der mit der jeweiligen Schriftart angegebenen Kerningtabellen angepasst werden sollen, oder ob das automatische Kerning stattdessen deaktiviert und der Zeichenzwischenraum auf eine bestimmte Länge festgelegt werden soll." standard-reference="http://www.w3.org/TR/SVG11/text.html#KerningProperty">

    <entry _locID="kerning_none" _locAttrData="description" value="auto" description="Gibt an, dass die Abstände zwischen Glyphen vom Benutzer-Agent auf der Grundlage der Kerningtabellen, die mit der zu verwendenden Schriftart angegeben werden, angepasst werden sollen." />
  </CssProperty>

