<CssModule name="Lists" standard-reference="https://www.w3.org/TR/css3-lists/" status="WD" pub-date="2020-11-17">

    <CssProperty _locID="list-style-image" _locAttrData="description" version="1.0" restriction="enum, url" type="list-style-image" description="Legt das Bild fest, das als Aufzählungszeichen für Listenelemente verwendet wird: Wenn das Bild verfügbar ist, ersetzt es das mit 'list-style-type' festgelegte Aufzählungszeichen." syntax="&lt;uri&gt; | none" standard-reference="https://www.w3.org/TR/css-lists-3/#image-markers" />

    <CssProperty _locID="list-style-type" _locAttrData="description" version="1.0" browsers="all" restriction="enum, string" type="list-style-type" description="Wird verwendet, um ein Element wie ein Standard-Benutzeroberflächenelement auf der Plattform zu gestalten." syntax="&lt;glyph&gt; | &lt;algorithmic&gt; | &lt;numeric&gt; | &lt;alphabetic&gt; | &lt;symbolic&gt; | &lt;non-repeating&gt; | normal | none" standard-reference="https://www.w3.org/TR/css-lists-3/#text-markers" />

    <CssProperty _locID="list-style-position" _locAttrData="description" version="1.0" restriction="enum" type="list-style-position" syntax="ul { $(name): inside; }" description="Gibt die Position der Box des '::marker'-Pseudoelements im Listenelement an." standard-reference="https://www.w3.org/TR/css-lists-3/#list-style-position-property" />

    <CssProperty _locID="list-style" _locAttrData="description" version="1.0" restriction="enum, url" type="list-style-type, list-style-position, list-style-image" description="Kurzschreibweise zum Festlegen von 'list-style-type', 'list-style-position' und 'list-style-image'." syntax="ul { $(name): square url('square.png');}" standard-reference="https://www.w3.org/TR/css-lists-3/#list-style-property" />

    <CssPropertyValue type="list-style-type" extends="counter-style">
        <entry value="none" />
    </CssPropertyValue>

    <CssPropertyValue type="list-style-image" extends="image">
      <entry value="none" />
    </CssPropertyValue>

    <CssPropertyValue type="list-style-position">
      <entry _locID="list-style-position_inside" _locAttrData="description" value="inside" description="Das Aufzählungszeichens befindet sich außerhalb der Box des Hauptblocks wie im Abschnitt zum '::marker'-Pseudoelement unten beschrieben." />
      <entry _locID="list-style-position_outside" _locAttrData="description" value="outside" description="Das '::marker'-Pseudoelement ist ein Inlineelement, das in der Box des Hauptblocks unmittelbar vor allen '::before'-Pseudoelementen platziert ist (der Inhalt des Elements fließt rechts daran vorbei)." />
    </CssPropertyValue>

    <CssProperty _locID="marker-side" _locAttrData="description" restriction="enum" description="Die markerseitige Eigenschaft gibt an, ob ein externes Markerfeld basierend auf der Richtung des Listenelements selbst (d. h. seinem ursprünglichen Element) oder der Richtung des Listencontainers (d. h. dem übergeordneten Element des Ursprungselements) positioniert wird." syntax="li { $(name): match-parent" standard-reference="https://www.w3.org/TR/css-lists-3/#marker-side">

      <entry value="match-self" />
      <entry value="match-parent" />
    </CssProperty>

    <CssProperty _locID="counter-reset" _locAttrData="description" description="Die Eigenschaft zum Zurücksetzen von Zählern instanziiert neue Leistungsindikatoren für ein Element und legt sie auf die angegebenen ganzzahligen Werte fest." syntax=".tableOfContents { $(name): chapter-count 5;" standard-reference="https://www.w3.org/TR/css-lists-3/#counter-reset">
      <entry value="none" />
    </CssProperty>

    <CssProperty _locID="counter-increment" _locAttrData="description" ref="counter-reset" description="Die Eigenschaften &quot;counter-increment&quot; und &quot;counter-set&quot; ändern den Wert vorhandener Leistungsindikatoren. Sie instanziieren neue Leistungsindikatoren nur, wenn für das Element noch kein Zähler mit dem angegebenen Namen vorhanden ist." standard-reference="https://www.w3.org/TR/css-lists-3/#increment-set" />

    <CssProperty _locID="counter-set" ref="counter-increment" />

  <CssPropertyValue type="counter">
    <entry _locID="content_counterN" _locAttrData="description" value="counter(name)" description="Zähler sind durch Bezeichner gekennzeichnet (siehe die 'counter-increment'-Eigenschaft und die 'counter-reset'-Eigenschaft)." />
    <entry _locID="content_counterNSty" _locAttrData="description" value="counter(name, style)" browsers="none" description="Zähler sind durch Bezeichner gekennzeichnet (siehe die 'counter-increment'-Eigenschaft und die 'counter-reset'-Eigenschaft)." />
    <entry _locID="content_counterstr" _locAttrData="description" value="counters(name, string)" browsers="none" description="Zähler sind durch Bezeichner gekennzeichnet (siehe die 'counter-increment'-Eigenschaft und die 'counter-reset'-Eigenschaft)." />
    <entry _locID="content_countersNSS" _locAttrData="description" browsers="none" value="counters(name, string, style)" description="Zähler sind durch Bezeichner gekennzeichnet (siehe die 'counter-increment'-Eigenschaft und die 'counter-reset'-Eigenschaft)." />
  </CssPropertyValue>

