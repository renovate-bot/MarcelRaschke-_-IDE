<CssModule name="Paged Media" standard-reference="https://www.w3.org/TR/css-page-3/" status="WD" pub-date="2018-10-18">

  <CssAtDirective name="page" _locID="page-rule" _locAttrData="description" version="2.0" include-root-directives="false" syntax="@page" description="Die Regel definiert verschiedene Seitenparameter." standard-reference="https://www.w3.org/TR/css-page-3/#page-box-page-rule">

    <CssPseudo name=":right" _locID="right-page-selector" _locAttrData="description" version="2.0" type="pseudo-class" syntax="@page :right { margin-left: 4cm; }" description="Die Seitenboxen auf linken und rechten Seiten können bei der Ausgabe doppelseitiger Dokumente unterschiedlich sein. Dies kann durch CSS-Pseudoklassen ausgedrückt werden, die im Seitenkontext definiert sind." standard-reference="https://www.w3.org/TR/css-page-3/#left-right-first" />

    <CssPseudo name=":left" _locID="left-page-selector" _locAttrData="description" version="2.0" type="pseudo-class" syntax="@page :left { margin-left: 4cm; }" description="Die Seitenboxen auf linken und rechten Seiten können bei der Ausgabe doppelseitiger Dokumente unterschiedlich sein. Dies kann durch CSS-Pseudoklassen ausgedrückt werden, die im Seitenkontext definiert sind." standard-reference="https://www.w3.org/TR/css-page-3/#left-right-first" />

    <CssPseudo name=":first" _locID="first-page-selector" _locAttrData="description" version="2.0" type="pseudo-class" syntax="@page :first { margin-left: 4cm; }" description="Die Seitenboxen auf linken und rechten Seiten können bei der Ausgabe doppelseitiger Dokumente unterschiedlich sein. Dies kann durch CSS-Pseudoklassen ausgedrückt werden, die im Seitenkontext definiert sind." standard-reference="https://www.w3.org/TR/css-page-3/#left-right-first" />

    <CssProperty _locID="size" version="2.1" browsers="C,O8" type="page-size" restriction="length" syntax="&lt;length&gt;{1,2} | auto | [ &lt;page-size&gt; || [ portrait | landscape] ]" standard-reference="https://www.w3.org/TR/css-page-3/#page-size-prop">

      <entry _locID="size_auto" _locAttrData="description" value="auto" description="Die Seitenbox wird auf die Größe und Ausrichtung des vom Benutzer-Agent ausgewählten Seitenblatts festgelegt." />
      <entry _locID="size_portrait" _locAttrData="description" value="portrait" description="Gibt an, dass der Inhalt der Seite im Hochformat gedruckt wird." />
      <entry _locID="size_landscape" _locAttrData="description" value="landscape" description="Gibt an, dass der Inhalt der Seite im Querformat gedruckt wird." />
    </CssProperty>

    <CssProperty _locID="marks" _locAttrData="description" version="2.0-2.0" browsers="none" restriction="enum" description="Fügt auf Seitenmedien Schneidemarken ein, damit Ausdrucke zugeschnitten und ausgerichtet werden können.">

      <entry _locID="marks_crop" _locAttrData="description" value="crop" description="Schneidemarken werden auf der Seite gedruckt." />
      <entry _locID="marks_" _locAttrData="description" value="cross" description="Passmarken werden auf der Seite gedruckt." />
      <entry _locID="marks_" _locAttrData="description" value="none" description="Auf der Seite werden keine Schneide- oder Passmarken gedruckt." />
    </CssProperty>

    <CssProperty _locID="bleed" _locAttrData="description" restriction="length" description="Die Erweiterung hinter dem Seitenfeld, an dem das Seitenrendering abgeschnitten wird." standard-reference="https://www.w3.org/TR/css-page-3/#bleed">
      <entry _locID="bleed_auto" _locAttrData="description" value="auto" description="Berechnet auf 6pt, wenn Markierungen zugeschnitten wurden, andernfalls auf 0 (null)." />
    </CssProperty>

    <CssAtDirective name="top-left" _locID="top-left-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite innerhalb des Bereichs, der durch den oberen Rand definiert wird, und die an die obere linke Randbox angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="top-left-corner" _locID="top-left-corner-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box fester Größe, die den Bereich ausfüllt, der durch den Schnittpunkt des oberen und linken Rands der Seitenbox definiert wird." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="top-center" _locID="top-center-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite, die durch den oberen Rand definiert wird, auf der Seitenfläche zentriert ist und zwischen der oberen linken und oberen rechten Randbox liegt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="top-right" _locID="top-right-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite innerhalb des Bereichs, der durch den oberen Rand definiert wird, und die an die obere rechte Randbox angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="top-right-corner" _locID="top-right-corner-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box, die den Bereich ausfüllt, der durch den Schnittpunkt des oberen und rechten Rands der Seitenbox definiert wird." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="left-top" _locID="left-top-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe innerhalb des durch den linken Rand definierten Bereichs, die am unteren Rand der oberen linken Ecke angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="left-middle" _locID="left-middle-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe, die durch den linken Rand definiert wird, auf der Seitenfläche zentriert ist und zwischen der oberen linken und unteren linken Randbox liegt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="left-bottom" _locID="left-bottom-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe innerhalb des durch den linken Rand definierten Bereichs, die am oberen Rand der unteren linken Ecke angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="right-top" _locID="right-top-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe innerhalb des durch den rechten Rand definierten Bereichs, die am unteren Rand der oberen rechten Ecke angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="right-middle" _locID="right-middle-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe, die durch den rechten Rand definiert wird, auf der Seitenfläche zentriert ist und zwischen der oberen rechten und unteren rechten Randbox liegt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="right-bottom" _locID="right-bottom-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Höhe innerhalb des durch den rechten Rand definierten Bereichs, die am oberen Rand der unteren rechten Ecke angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="bottom-left-corner" _locID="bottom-left-corner-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box, die den Bereich ausfüllt, der durch den Schnittpunkt des unteren und linken Rands der Seitenbox definiert wird." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="bottom-left" _locID="bottom-left-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite innerhalb des Bereichs, der durch den unteren Rand definiert wird, und die an die untere linke Randbox angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="bottom-center" _locID="bottom-center-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite, die durch den unteren Rand definiert wird, auf der Seitenfläche zentriert ist und zwischen der unteren linken und unteren rechten Randbox liegt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="bottom-right" _locID="bottom-right-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box variabler Breite innerhalb des Bereichs, der durch den unteren Rand definiert wird, und die an die untere rechte Randbox angrenzt." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

    <CssAtDirective name="bottom-right-corner" _locID="bottom-center-page-rule" _locAttrData="description" version="3" browsers="none" description="Eine Box, die den Bereich ausfüllt, der durch den Schnittpunkt des unteren und rechten Rands der Seitenbox definiert wird." standard-reference="https://www.w3.org/TR/css-page-3/#page-box" />

  </CssAtDirective>

  <CssPropertyValue type="page-size" version="3.0">
    <entry _locID="page-size-val_A5" _locAttrData="description" value="A5" description="ISO-A5-Medien: 148 mm breit und 210 mm hoch" />
    <entry _locID="page-size-val_A4" _locAttrData="description" value="A4" description="ISO-A4-Medien: 210 mm breit und 297 mm hoch" />
    <entry _locID="page-size-val_A3" _locAttrData="description" value="A3" description="ISO-A3-Medien: 297 mm breit und 420 mm hoch" />
    <entry _locID="page-size-val_B5" _locAttrData="description" value="B5" description="ISO-B5-Medien: 176 mm breit und 250 mm hoch" />
    <entry _locID="page-size-val_B4" _locAttrData="description" value="B4" description="ISO-B4-Medien: 250 mm breit und 353 mm hoch" />
    <entry _locID="page-size-val_letter" _locAttrData="description" value="letter" description="Nordamerikanisches Letter-Format: 8,5 Zoll breit und 11 Zoll hoch" />
    <entry _locID="page-size-val_legal" _locAttrData="description" value="legal" description="Nordamerikanisches Legal-Format: 8,5 Zoll breit und 14 Zoll hoch" />
    <entry _locID="page-size-val_ledger" _locAttrData="description" value="ledger" description="Nordamerikanisches Ledger-Format: 11 Zoll breit und 17 Zoll hoch" />
  </CssPropertyValue>

  <CssProperty _locID="page" _locAttrData="description" version="3.0" browsers="none" restriction="identifier" syntax="auto | &lt;identifier&gt;" description="Legt einen bestimmten Seitentyp fest, auf dem ein Element angezeigt werden SOLL." standard-reference="https://www.w3.org/TR/css-page-3/#page">

    <entry value="auto" />
  </CssProperty>

