<CssModule name="Basic User Interface" standard-reference="https://www.w3.org/TR/css-ui-4/" status="WD" pub-date="2021-03-16">

  <CssProperty _locID="outline" _locAttrData="description" ref="border" version="2.0" browsers="C,FF1.5,IE8,O8,S1.2" description="Kurzschreibweise zur Festlegung der drei Eigenschaften 'outline-style', 'outline-width' und 'outline-color'." standard-reference="https://www.w3.org/TR/css-ui-4/#outline">

      <entry version="3.0" value="auto" />
      <entry _locID="outline_invert" _locAttrData="description" value="invert" description="Von &quot;Invert&quot; wird die Farbinversion der Pixel auf dem Bildschirm erwartet. Dies ist eine verbreitete Methode, um sicherzustellen, dass der Fokusrahmen unabhängig von der Farbe des Hintergrunds sichtbar ist." />
  </CssProperty>

  <CssProperty _locID="outline-width" _locAttrData="description" ref="border-width" version="2.0" browsers="C,FF1.5,IE8,O8,S1.2" description="Die Breite der Kontur." standard-reference="https://www.w3.org/TR/css-ui-4/#outline-width" />

  <CssProperty _locID="outline-style" _locAttrData="description" ref="border-style" version="2.0" browsers="C,FF1.5,IE8,O8,S1.2" description="Der Stil der Kontur." standard-reference="https://www.w3.org/TR/css-ui-4/#outline-style">
      <entry version="3.0" value="auto" />
  </CssProperty>

  <CssProperty _locID="outline-color" _locAttrData="description" ref="color" version="2.0" browsers="C,FF1.5,IE8,O8,S1.2" description="Die Farbe der Kontur." standard-reference="https://www.w3.org/TR/css-ui-4/#outline-color">

      <entry _locID="outline-color_invert" _locAttrData="description" value="invert" description="Von 'Invert' wird die Farbinversion der Pixel auf dem Bildschirm erwartet. Dies ist eine verbreitete Methode, um sicherzustellen, dass der Fokusrahmen unabhängig vom Farbhintergrund sichtbar ist." />
  </CssProperty>

  <CssProperty _locID="outline-offset" _locAttrData="description" version="3.0" browsers="C,FF1.5,O9.5,S1.2" restriction="length" syntax="article { $(name): 15px; }" description="Die Breite der Kontur." standard-reference="https://www.w3.org/TR/css-ui-4/#outline-offset">
  </CssProperty>

  <CssProperty _locID="resize" _locAttrData="description" version="3.0" browsers="C,FF4,S3" restriction="enum" syntax="div { $(name): both; }" description="Ermöglicht die Steuerung der Darstellung und Funktion des Größenänderungsmechanismus (z.B. eines Größenänderungsfelds oder Widgets) für das Element. Bezieht sich auf Elemente, deren 'overflow'-Eigenschaft auf einen anderen Wert als 'visible' festgelegt wurde." standard-reference="https://www.w3.org/TR/css-ui-4/#resize">

      <entry _locID="resize_none" _locAttrData="description" value="none" description="Der Benutzer-Agent stellt keinen Größenänderungsmechanismus für das Element bereit, und der Benutzer erhält keine direkte Bearbeitungsmöglichkeit zum Ändern der Elementgröße." />
      <entry _locID="resize_both" _locAttrData="description" value="both" description="Der Benutzer-Agent stellt einen bidirektionalen Größenänderungsmechanismus bereit, über den der Benutzer sowohl die Höhe als auch die Breite des Elements anpassen kann." />
      <entry _locID="resize_horizontal" _locAttrData="description" value="horizontal" description="Der Benutzer-Agent stellt einen unidirektionalen Mechanismus zur Änderung der horizontalen Größe bereit, über den der Benutzer nur die Breite des Elements anpassen kann." />
      <entry _locID="resize_vertical" _locAttrData="description" value="vertical" description="Der Benutzer-Agent stellt einen unidirektionalen Mechanismus zur Änderung der vertikalen Größe bereit, über den der Benutzer nur die Höhe des Elements anpassen kann." />
      <entry _locID="resize_block" _locAttrData="description" value="block" description="Der Benutzer-Agent stellt einen unidirektionalen Mechanismus zur Änderung der Größe der Blockachse bereit, über den der Benutzer nur die Blockgröße des Elements anpassen kann." />
      <entry _locID="resize_inline" _locAttrData="description" value="inline" description="Der Benutzer-Agent stellt einen unidirektionalen Mechanismus zur Änderung der Größe der Inlineachse bereit, damit der Benutzer nur die Inlinegröße des Elements anpassen kann." />
  </CssProperty>

  <CssProperty _locID="cursor" _locAttrData="description" version="2.0" restriction="url, number" description="Ermöglicht die Steuerung der Cursordarstellung in einem Element." syntax="nav { $(name): pointer; }" standard-reference="http://www.w3.org/TR/css3-ui/#cursor0">

      <entry _locID="cursor_auto" _locAttrData="description" value="auto" description="Der Benutzer-Agent bestimmt, welcher Cursor je nach Kontext angezeigt werden soll." />
      <entry _locID="cursor_default" _locAttrData="description" value="default" description="Der plattformabhängige Standardcursor, der häufig als Pfeil dargestellt wird." />
      <entry _locID="cursor_none" _locAttrData="description" value="none" version="3.0" description="Für das Element wird kein Cursor dargestellt." />
      <entry _locID="cursor_context-menu" _locAttrData="description" value="context-menu" version="3.0" description="Ein Kontextmenü ist unterhalb des Cursors für das Objekt verfügbar. Wird häufig als Pfeil mit einer kleinen menüähnlichen Grafik dargestellt." />
      <entry _locID="cursor_help" _locAttrData="description" value="help" description="Hilfe ist unterhalb des Cursors für das Objekt verfügbar. Wird häufig als Fragezeichen oder Sprechblase dargestellt." />
      <entry _locID="cursor_pointer" _locAttrData="description" value="pointer" description="Der Cursor ist ein Zeiger, der einen Link angibt." />
      <entry _locID="cursor_progress" _locAttrData="description" value="progress" version="2.1" description="Eine Statusanzeige. Obwohl das Programm einige Verarbeitungsschritte ausführt, unterscheidet sich dieser Cursor von einem normalen Wartecursor, weil der Benutzer weiterhin mit dem Programm interagieren kann. Wird häufig als sich drehender Ball oder als Pfeil mit einer Uhr oder einer Sanduhr dargestellt." />
      <entry _locID="cursor_wait" _locAttrData="description" value="wait" description="Gibt an, dass das Programm beschäftigt ist und der Benutzer warten soll. Wird häufig als Uhr oder Sanduhr dargestellt." />
      <entry _locID="cursor_cell" _locAttrData="description" value="cell" version="3.0" description="Gibt an, dass eine Zelle oder eine Gruppe von Zellen ausgewählt werden kann. Wird häufig als dickes Pluszeichen mit einem Punkt in der Mitte dargestellt." />
      <entry _locID="cursor_crosshair" _locAttrData="description" value="crosshair" description="Ein einfaches Fadenkreuz (d.h., kurze Liniensegmente, die einem '+'-Zeichen ähneln). Wird häufig verwendet, um einen Auswahlmodus für eine zweidimensionale Bitmapgrafik anzuzeigen." />
      <entry _locID="cursor_text" _locAttrData="description" value="text" description="Zeigt an, dass Text ausgewählt werden kann. Wird häufig als vertikaler I-Balken dargestellt." />
      <entry _locID="cursor_vertical-text" _locAttrData="description" value="vertical-text" version="3.0" description="Zeigt vertikalen Text an, der ausgewählt werden kann. Wird häufig als horizontaler I-Balken dargestellt." />
      <entry _locID="cursor_alias" _locAttrData="description" value="alias" version="3.0" description="Zeigt einen Alias von bzw. eine Verknüpfung zu einem Element an, das erstellt werden soll. Wird häufig als Pfeil mit einem kleinen gekrümmten Pfeil angezeigt." />
      <entry _locID="cursor_copy" _locAttrData="description" value="copy" version="3.0" description="Zeigt an, das ein Element kopiert werden muss. Wird häufig als Pfeil mit einem kleinen Pluszeichen angezeigt." />
      <entry _locID="cursor_move" _locAttrData="description" value="move" description="Gibt an, dass ein Element verschoben werden muss." />
      <entry _locID="cursor_no-drop" _locAttrData="description" value="no-drop" version="3.0" description="Zeigt an, dass das gezogene Element nicht an der aktuellen Cursorposition abgelegt werden kann. Wird häufig als Hand oder Zeiger mit einem kleinen durchgestrichenen Kreis dargestellt." />
      <entry _locID="cursor_not-allowed" _locAttrData="description" value="not-allowed" version="3.0" description="Zeigt an, dass die angeforderte Aktion nicht ausgeführt wird. Wird häufig als durchgestrichener Kreis dargestellt." />
      <entry _locID="cursor_grab" _locAttrData="description" value="grab" version="3.0" description="Gibt an, dass ein Element erfasst (gezogen, um verschoben zu werden) werden kann. Wird häufig als der Handrücken einer geöffneten Hand gerendert." />
      <entry _locID="cursor_grabbing" _locAttrData="description" value="grabbing" version="3.0" description="Gibt an, dass ein Element aktuell erfasst (gezogen, um verschoben zu werden) wird. Wird häufig als der Handrücken einer Hand mit geschlossenen Fingern größtenteils außerhalb des Sichtfelds gerendert." />
      <entry _locID="cursor_e-resize" _locAttrData="description" value="e-resize" description="Gibt an, dass der rechte Rand (Ost) verschoben werden muss." />
      <entry _locID="cursor_n-resize" _locAttrData="description" value="n-resize" description="Gibt an, dass der obere Rand (Nord) verschoben werden muss." />
      <entry _locID="cursor_ne-resize" _locAttrData="description" value="ne-resize" description="Gibt an, dass der Verschiebevorgang in der oberen rechten Ecke (Nordost) startet." />
      <entry _locID="cursor_nw-resize" _locAttrData="description" value="nw-resize" description="Gibt an, dass der Verschiebevorgang in der oberen linken Ecke (Nordwest) startet." />
      <entry _locID="cursor_s-resize" _locAttrData="description" value="s-resize" description="Gibt an, dass der untere Rand (Süd) verschoben werden muss." />
      <entry _locID="cursor_se-resize" _locAttrData="description" value="se-resize" description="Gibt an, dass der Verschiebevorgang in der unteren rechten Ecke (Südost) startet." />
      <entry _locID="cursor_sw-resize" _locAttrData="description" value="sw-resize" description="Gibt an, dass der Verschiebevorgang in der unteren linken Ecke (Südwest) startet." />
      <entry _locID="cursor_w-resize" _locAttrData="description" value="w-resize" description="Gibt an, dass der linke Rand (West) verschoben werden muss." />
      <entry _locID="cursor_ew-resize" _locAttrData="description" value="ew-resize" version="3.0" description="Gibt einen bidirektionalen Größenänderungscursor (Ostwest) an." />
      <entry _locID="cursor_ns-resize" _locAttrData="description" value="ns-resize" version="3.0" description="Gibt einen bidirektionalen Cursor (Nordsüd) an." />
      <entry _locID="cursor_nesw-resize" _locAttrData="description" value="nesw-resize" version="3.0" description="Gibt einen bidirektionalen Cursor (Nordost/Südwest) an." />
      <entry _locID="cursor_nwse-resize" _locAttrData="description" value="nwse-resize" version="3.0" description="Gibt einen bidirektionalen Cursor (Nordwest/Südost) an." />
      <entry _locID="cursor_col-resize" _locAttrData="description" value="col-resize" version="3.0" description="Gibt an, dass die Größe des Elements oder der Spalte horizontal geändert werden kann. Wird häufig in Form eines nach links und rechts weisenden Doppelpfeils mit einem vertikalen Balken in der Mitte angezeigt." />
      <entry _locID="cursor_row-resize" _locAttrData="description" value="row-resize" version="3.0" description="Gibt an, dass die Größe des Elements oder der Zeile vertikal geändert werden kann. Wird häufig in Form eines nach oben und unten weisenden Doppelpfeils mit einem horizontalen Balken in der Mitte angezeigt." />
      <entry _locID="cursor_all-scroll" _locAttrData="description" value="all-scroll" version="3.0" description="Gibt an, dass für ein Element ein Bildlauf in eine beliebige Richtung ausgeführt werden kann. Wird häufig in Form von Pfeilen dargestellt, die nach oben, unten, links und rechts weisen und in der Mitte einen Punkt aufweisen." />
      <entry _locID="cursor_zoom-in" _locAttrData="description" value="zoom-in" version="3.0" browsers="none" description="Gibt an, dass ein Element vergrößert bzw. verkleinert (gezoomt) werden kann und wird häufig als Lupe gerendert, in deren Glas ein '+' für die Vergrößerungsfunktion bzw. ein '-' für die Verkleinerungsfunktion dargestellt ist." />
      <entry _locID="cursor_zoom-out" _locAttrData="description" value="zoom-out" version="3.0" browsers="none" description="Gibt an, dass ein Element vergrößert bzw. verkleinert (gezoomt) werden kann und wird häufig als Lupe gerendert, in deren Glas ein '+' für die Vergrößerungsfunktion bzw. ein '-' für die Verkleinerungsfunktion dargestellt ist." />
  </CssProperty>

  <CssProperty _locID="caret-color" _locAttrData="description" restriction="color" description="Das Caretzeichen ist ein sichtbarer Indikator für die Einfügemarke in einem Element, in das Text (und potenziell anderer Inhalt) vom Benutzer eingefügt wird. Diese Eigenschaft steuert die Farbe dieses sichtbaren Indikators." syntax="input { $(name): red; }" standard-reference="https://www.w3.org/TR/css-ui-4/#caret-color">

      <entry value="auto" />
  </CssProperty>

  <CssPropertyValue type="caret-shape">
    <entry value="auto" />
    <entry value="bar" />
    <entry value="block" />
    <entry value="underscore" />
  </CssPropertyValue>

  <CssProperty _locID="caret-shape" _locAttrData="description" type="caret-shape" restriction="enum" description="Mit dieser Eigenschaft können Autoren die gewünschte Form des Caretzeichens für die Texteinfügung angeben." syntax="input { $(name): bar; }" standard-reference="https://www.w3.org/TR/css-ui-4/#caret-shape" />

  <CssProperty _locID="caret" _locAttrData="description" type="caret-shape" restriction="color, enum" description="Diese Eigenschaft ist eine Kurzform zum Festlegen der Farbe und der Form des Caretzeichens in einer Deklaration." syntax="input { $(name): red bar; }" standard-reference="https://www.w3.org/TR/css-ui-4/#caret" />

  <CssProperty _locID="nav-up" _locAttrData="description" version="3.0" browsers="O9.5" restriction="enum, identifier, string" description="Bietet eine Möglichkeit zur Steuerung der richtungsbasierten Fokusnavigation." syntax="auto | 'id' [ current | root | 'target-name' ]?" standard-reference="https://www.w3.org/TR/css-ui-4/#nav-dir">

    <entry value="auto" description="The user agent automatically determines which element to navigate the focus to in response to directional navigational input." />
    <entry value="current" />
    <entry value="root" />
  </CssProperty>

  <CssProperty _locID="nav-left" ref="nav-up" browsers="O9.5" />
  <CssProperty _locID="nav-right" ref="nav-up" browsers="O9.5" />
  <CssProperty _locID="nav-down" ref="nav-up" browsers="O9.5" />

  <CssProperty _locID="user-select" _locAttrData="description" version="3.0" browsers="none" restriction="enum" syntax="div { $(name): text; }" description="Steuert die Darstellung einer Auswahl." standard-reference="https://www.w3.org/TR/css-ui-4/#content-selection">

    <entry value="auto" />
    <entry value="text" />
    <entry value="none" />
    <entry value="contain" />
    <entry value="all" />
  </CssProperty>

  <CssProperty _locID="accent-color" _locAttrData="description" restriction="color" syntax="input { $(name): blue; }" description="Ermöglicht es dem Autor, die Akzentfarbe für Steuerelemente der Benutzeroberfläche anzugeben, die vom Element generiert werden." standard-reference="https://www.w3.org/TR/css-ui-4/#widget-accent">
    <entry value="auto" />
  </CssProperty>

  <CssProperty _locID="appearance" _locAttrData="description" restriction="enum" syntax="input { $(name): textfield; }" description="Wird verwendet, um ein Element mit plattformnativer Formatierung basierend auf dem Design des Betriebssystems anzuzeigen." standard-reference="https://www.w3.org/TR/css-ui-4/#appearance-switching">
    <entry value="none" />
    <entry value="auto" />
    <entry value="textfield" />
    <entry value="menulist-button" />
    <entry value="searchfield" />
    <entry value="textarea" />
    <entry value="push-button" />
    <entry value="slider-horizontal" />
    <entry value="checkbox" />
    <entry value="radio" />
    <entry value="square-button" />
    <entry value="menulist" />
    <entry value="listbox" />
    <entry value="meter" />
    <entry value="progress-bar" />
    <entry value="button" />
  </CssProperty>

