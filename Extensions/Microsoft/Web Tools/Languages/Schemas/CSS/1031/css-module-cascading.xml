<CssModule name="Cascading and Inheritance" standard-reference="https://www.w3.org/TR/css-cascade-5" status="CR" pub-date="2022-01-13">

  <CssAtDirective name="import" _locID="import-rule" _locAttrData="description" syntax="@import url('file.css') tv, print;" description="Importiert Inhalte aus einer anderen Datei." standard-reference="https://www.w3.org/TR/css-cascade-5/#at-import" />

  <CssAtDirective name="layer" _locID="layer-rule" _locAttrData="description" syntax="@layer framework {};" description="Deklariert eine Kaskadierenschicht." standard-reference="https://www.w3.org/TR/css-cascade-5/#at-layer" />

  <CssPropertyValue type="all">
    <entry _locID="all-val_inherit" _locAttrData="description" value="inherit" description="Das Element übernimmt den berechneten Wert des übergeordneten Elements für die Eigenschaft." />
    <entry _locID="all-val_initial" _locAttrData="description" value="initial" description="Der Standardwert einer beliebigen Eigenschaft." />
    <entry _locID="all-val_unset" _locAttrData="description" value="unset" description="Wenn der kaskadierende Wert einer Eigenschaft das Schlüsselwort &quot;unset&quot; ist und es sich um eine geerbte Eigenschaft handelt, wird dieser Wert als &quot;inherit&quot; behandelt. Andernfalls wird er als &quot;initial&quot; behandelt." />
    <entry _locID="all-val_revert" _locAttrData="description" value="revert" description="Wenn der kaskadierte Wert einer Eigenschaft das Schlüsselwort 'revert' ist, hängt das Verhalten vom Kaskadenursprung ab, zu dem die Deklaration gehört." />
    <entry _locID="all-val_revert-layer" _locAttrData="description" value="revert-layer" description="Wenn der kaskadierte Wert einer Eigenschaft das Schlüsselwort &quot;revert-layer&quot; ist, wird der kaskadierte Wert auf die darunter liegende Ebene zurückgesetzt, so dass der angegebene Wert so berechnet wird, als ob in der aktuellen Kaskadenebene keine Regeln angegeben wären." />
  </CssPropertyValue>

