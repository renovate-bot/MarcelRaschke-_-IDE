<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5.2" />
    </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <!-- 
            Azure Data Lake SDK expect 6.0 of Newtonsoft.Json,
            8.0.0.0 fails as tested, 
            10.0.0.0 looks to work by limited tests, and there are other new codes build against 10.0
            so we will assume this for U-SQL SDK
        -->
        <bindingRedirect oldVersion="0.0.0.0-10.0.0.0" newVersion="10.0.0.0" />  
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>