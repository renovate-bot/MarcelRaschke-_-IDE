<VSTemplate Version="2.0.0" Type="Item" xmlns="http://schemas.microsoft.com/developer/vstemplate/2005">
  <TemplateData>
    <Name>Storm Batch Bolt</Name>
    <Description>An batch bolt file for storm topology</Description>
    <Icon>StormBatchBolt.png</Icon>
    <ProjectType>CSharp</ProjectType>
    <DefaultName>BatchBolt.cs</DefaultName>
    <ProvideDefaultName>true</ProvideDefaultName>
    <Hidden>false</Hidden>
  </TemplateData>
  <TemplateContent>
    <ProjectItem ReplaceParameters="true" TargetFileName="$fileinputname$.cs" OpenInEditor="true">StormBatchBolt.cs</ProjectItem>
  </TemplateContent>
</VSTemplate>